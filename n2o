# Format a number with commas (e.g., 1234567 -> 1,234,567)
format_number() {
  local n="$1"
  # Handle empty/null
  if [[ -z "$n" || "$n" == "null" ]]; then
    echo "0"
    return
  fi
  # Use printf with locale-aware grouping, fall back to awk
  # LC_NUMERIC=en_US printf is unreliable across platforms, so use awk
  printf "%d" "$n" 2>/dev/null | awk '{
    s = $0
    len = length(s)
    out = ""
    for (i = len; i > 0; i--) {
      out = substr(s, i, 1) out
      if ((len - i + 1) % 3 == 0 && i > 1)
        out = "," out
    }
    print out
  }'
}

cmd_stats() {
  local json_output=false

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_output=true; shift ;;
      -*)     log_error "Unknown option: $1"; exit 1 ;;
      *)      log_error "Unknown argument: $1"; exit 1 ;;
    esac
  done

  local db="$N2O_DIR/.pm/tasks.db"

  # Check for database
  if [[ ! -f "$db" ]]; then
    log_error "Database not found at $db"
    log_error "Run 'n2o init' first, then populate the database."
    exit 1
  fi

  # Auto-refresh transcript data if the collection script exists
  if [[ -f "$N2O_DIR/scripts/collect-transcripts.sh" ]]; then
    if ! $json_output; then
      log_info "Refreshing transcript data..."
    fi
    (cd "$N2O_DIR" && bash scripts/collect-transcripts.sh) &>/dev/null || true
  fi

  # ---- JSON output mode ----
  if $json_output; then
    local sessions_json tool_usage_json sprint_json available_json

    sessions_json=$(sqlite3 -json "$db" "
      SELECT
        COUNT(*) FILTER (WHERE parent_session_id IS NULL) as main_sessions,
        COUNT(*) FILTER (WHERE parent_session_id IS NOT NULL) as subagent_sessions,
        COUNT(*) as total_sessions,
        MAX(started_at) as last_session,
        MAX(session_id) as last_session_id,
        COALESCE(SUM(total_input_tokens), 0) as total_input_tokens,
        COALESCE(SUM(total_output_tokens), 0) as total_output_tokens
      FROM transcripts;
    " 2>/dev/null || echo "[]")

    tool_usage_json=$(sqlite3 -json "$db" "
      SELECT tool_name, invocations as calls, sessions
      FROM skill_usage
      ORDER BY invocations DESC
      LIMIT 10;
    " 2>/dev/null || echo "[]")

    sprint_json=$(sqlite3 -json "$db" "
      SELECT sprint, total_tasks as total, green as done, pending, percent_complete as pct
      FROM sprint_progress
      ORDER BY percent_complete DESC, sprint;
    " 2>/dev/null || echo "[]")

    available_json=$(sqlite3 -json "$db" "
      SELECT sprint, task_num, title, priority
      FROM available_tasks
      ORDER BY priority ASC NULLS LAST
      LIMIT 15;
    " 2>/dev/null || echo "[]")

    # Compose top-level JSON
    jq -n \
      --argjson sessions "$sessions_json" \
      --argjson tools "$tool_usage_json" \
      --argjson sprints "$sprint_json" \
      --argjson available "$available_json" \
      '{
        sessions: ($sessions[0] // {}),
        tool_usage: $tools,
        sprint_progress: $sprints,
        available_tasks: $available
      }'
    return
  fi

  # ---- Formatted terminal output ----

  # === Section 1: Session Summary ===
  log_header "Session Summary"

  local main_sessions subagent_sessions last_session last_session_id total_input total_output
  main_sessions=$(sqlite3 "$db" "SELECT COUNT(*) FROM transcripts WHERE parent_session_id IS NULL;" 2>/dev/null || echo "0")
  subagent_sessions=$(sqlite3 "$db" "SELECT COUNT(*) FROM transcripts WHERE parent_session_id IS NOT NULL;" 2>/dev/null || echo "0")
  last_session=$(sqlite3 "$db" "SELECT COALESCE(MAX(started_at), 'n/a') FROM transcripts;" 2>/dev/null || echo "n/a")
  last_session_id=$(sqlite3 "$db" "SELECT session_id FROM transcripts ORDER BY started_at DESC LIMIT 1;" 2>/dev/null || echo "unknown")
  total_input=$(sqlite3 "$db" "SELECT COALESCE(SUM(total_input_tokens), 0) FROM transcripts;" 2>/dev/null || echo "0")
  total_output=$(sqlite3 "$db" "SELECT COALESCE(SUM(total_output_tokens), 0) FROM transcripts;" 2>/dev/null || echo "0")

  # Truncate session_id display to first 8 chars
  local last_sid_display="${last_session_id:0:8}"
  # Truncate last_session to just the date portion if it has a time
  local last_date="${last_session%T*}"

  echo -e "  Sessions: ${BOLD}${main_sessions}${NC} main + ${BOLD}${subagent_sessions}${NC} subagent transcripts"
  echo -e "  Last session: ${last_date} (${last_sid_display}...)"
  echo -e "  Total tokens: ${BOLD}$(format_number "$total_input")${NC} input / ${BOLD}$(format_number "$total_output")${NC} output"

  # === Section 2: Tool Usage (top 10) ===
  log_header "Tool Usage (top 10)"

  local tool_data
  tool_data=$(sqlite3 -separator '|' "$db" "
    SELECT tool_name, invocations, sessions
    FROM skill_usage
    ORDER BY invocations DESC
    LIMIT 10;
  " 2>/dev/null || echo "")

  if [[ -n "$tool_data" ]]; then
    printf "  ${BOLD}%-20s %8s %8s${NC}\n" "Tool" "Calls" "Sessions"
    printf "  %-20s %8s %8s\n" "--------------------" "--------" "--------"
    while IFS='|' read -r tool_name calls sessions; do
      printf "  %-20s %8s %8s\n" "$tool_name" "$calls" "$sessions"
    done <<< "$tool_data"
  else
    echo -e "  ${YELLOW}No tool usage data available.${NC}"
  fi

  # === Section 3: Sprint Progress ===
  log_header "Sprint Progress"

  local sprint_data
  sprint_data=$(sqlite3 -separator '|' "$db" "
    SELECT sprint, total_tasks, green, pending, CAST(ROUND(percent_complete) AS INTEGER)
    FROM sprint_progress
    ORDER BY percent_complete DESC, sprint;
  " 2>/dev/null || echo "")

  if [[ -n "$sprint_data" ]]; then
    printf "  ${BOLD}%-22s %6s %6s %8s %5s${NC}\n" "Sprint" "Total" "Done" "Pending" "%"
    printf "  %-22s %6s %6s %8s %5s\n" "----------------------" "------" "------" "--------" "-----"
    while IFS='|' read -r sprint total done pending pct; do
      # Color the percentage: green if 100%, yellow if partial, default if 0%
      local pct_color="$NC"
      if [[ "$pct" == "100" ]]; then
        pct_color="$GREEN"
      elif [[ "$pct" -gt 0 ]] 2>/dev/null; then
        pct_color="$YELLOW"
      fi
      printf "  %-22s %6s %6s %8s ${pct_color}%4s%%${NC}\n" "$sprint" "$total" "$done" "$pending" "$pct"
    done <<< "$sprint_data"
  else
    echo -e "  ${YELLOW}No sprint data available.${NC}"
  fi

  # === Section 4: Available Tasks ===
  log_header "Available Tasks (next up)"

  local available_data
  available_data=$(sqlite3 -separator '|' "$db" "
    SELECT sprint, task_num, title, COALESCE(priority, 'n/a')
    FROM available_tasks
    ORDER BY priority ASC NULLS LAST
    LIMIT 15;
  " 2>/dev/null || echo "")

  if [[ -n "$available_data" ]]; then
    printf "  ${BOLD}%-16s %-50s %8s${NC}\n" "Sprint/#" "Title" "Priority"
    printf "  %-16s %-50s %8s\n" "----------------" "--------------------------------------------------" "--------"
    while IFS='|' read -r sprint task_num title priority; do
      local sprint_task="${sprint}/${task_num}"
      # Truncate title if too long
      if [[ ${#title} -gt 50 ]]; then
        title="${title:0:47}..."
      fi
      printf "  %-16s %-50s %8s\n" "$sprint_task" "$title" "$priority"
    done <<< "$available_data"
  else
    echo -e "  ${GREEN}No pending tasks — all caught up!${NC}"
  fi

  echo ""
}

# =============================================================================
# MIGRATE COMMAND
# =============================================================================

cmd_migrate() {
  local project_path=""
  local action=""
  local old_schema=""
  local new_schema=""

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --apply)    action="apply"; shift ;;
      --status)   action="status"; shift ;;
      --generate) action="generate"; shift ;;
      --old)      old_schema="$2"; shift 2 ;;
      --new)      new_schema="$2"; shift 2 ;;
      -*)         log_error "Unknown option: $1"; exit 1 ;;
      *)          project_path="$1"; shift ;;
    esac
  done

  if [[ -z "$action" ]]; then
    log_error "Usage: n2o migrate --apply|--status|--generate <project-path>"
    exit 1
  fi

  if [[ -z "$project_path" ]]; then
    log_error "Usage: n2o migrate --$action <project-path>"
    exit 1
  fi

  project_path="$(cd "$project_path" && pwd)"

  if [[ ! -f "$project_path/.pm/config.json" ]]; then
    log_error "Not an N2O project (missing .pm/config.json). Run 'n2o init' first."
    exit 1
  fi

  case "$action" in
    apply)
      log_header "Applying migrations: $project_path"
      apply_migrations "$project_path"
      ;;
    status)
      migrate_status "$project_path"
      ;;
    generate)
      generate_migration "$project_path" "$old_schema" "$new_schema"
      ;;
  esac
}

migrate_status() {
  local project_path="$1"
  local db="$project_path/.pm/tasks.db"
  local migrations_dir="$project_path/.pm/migrations"

  if [[ ! -f "$db" ]]; then
    log_error "Database not found: $db"
    exit 1
  fi

  # Ensure _migrations table exists
  sqlite3 "$db" "CREATE TABLE IF NOT EXISTS _migrations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,
    applied_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    framework_version TEXT,
    checksum TEXT
  );" 2>/dev/null

  local applied_count
  applied_count=$(sqlite3 "$db" "SELECT COUNT(*) FROM _migrations;" 2>/dev/null || echo "0")

  # Count pending (migration files not in _migrations)
  local pending_count=0
  if [[ -d "$migrations_dir" ]]; then
    local migration_files
    migration_files=$(find "$migrations_dir" -maxdepth 1 -name '*.sql' -type f 2>/dev/null | sort)
    if [[ -n "$migration_files" ]]; then
      while IFS= read -r f; do
        local name
        name=$(basename "$f" .sql)
        local is_applied
        is_applied=$(sqlite3 "$db" "SELECT COUNT(*) FROM _migrations WHERE name='$name';" 2>/dev/null)
        if [[ "$is_applied" == "0" ]]; then
          ((pending_count++)) || true
        fi
      done <<< "$migration_files"
    fi
  fi

  log_header "Migration Status: $(basename "$project_path")"
  echo -e "  ${BOLD}$applied_count${NC} applied, ${BOLD}$pending_count${NC} pending"

  if [[ "$applied_count" -gt 0 ]]; then
    echo ""
    echo -e "  ${BOLD}Applied:${NC}"
    sqlite3 "$db" "SELECT '    ' || name || ' (' || framework_version || ', ' || applied_at || ')' FROM _migrations ORDER BY id;" 2>/dev/null
  fi

  if [[ "$pending_count" -gt 0 ]]; then
    echo ""
    echo -e "  ${BOLD}Pending:${NC}"
    if [[ -d "$migrations_dir" ]]; then
      local migration_files
      migration_files=$(find "$migrations_dir" -maxdepth 1 -name '*.sql' -type f 2>/dev/null | sort)
      while IFS= read -r f; do
        local name
        name=$(basename "$f" .sql)
        local is_applied
        is_applied=$(sqlite3 "$db" "SELECT COUNT(*) FROM _migrations WHERE name='$name';" 2>/dev/null)
        if [[ "$is_applied" == "0" ]]; then
          echo "    $name"
        fi
      done <<< "$migration_files"
    fi
  fi

  echo ""
}

# Parse columns from a CREATE TABLE block (one column per line)
# Outputs: column_name<TAB>full_definition (one per line)
# Skips PRIMARY KEY lines, UNIQUE lines, CHECK lines, FOREIGN KEY lines
parse_table_columns() {
  local table_body="$1"
  echo "$table_body" | while IFS= read -r line; do
    # Trim whitespace
    local trimmed
    trimmed=$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
    # Skip empty, PRIMARY KEY, UNIQUE, CHECK, FOREIGN KEY, closing paren
    case "$trimmed" in
      "") continue ;;
      PRIMARY*) continue ;;
      UNIQUE*) continue ;;
      CHECK*) continue ;;
      FOREIGN*) continue ;;
      ");"*) continue ;;
      ")"*) continue ;;
    esac
    # Remove trailing comma
    trimmed="${trimmed%,}"
    # Extract column name (first word)
    local col_name
    col_name=$(echo "$trimmed" | awk '{print $1}')
    # Output: name<TAB>full_definition
    printf '%s\t%s\n' "$col_name" "$trimmed"
  done
}

# Extract table names and their bodies from a schema file
# Outputs blocks: TABLE_NAME<newline>body_lines<newline>END_TABLE
extract_tables() {
  local schema_file="$1"
  local in_table=false
  local table_name=""
  local body=""

  while IFS= read -r line; do
    if [[ "$line" =~ ^CREATE[[:space:]]+TABLE[[:space:]]+(IF[[:space:]]+NOT[[:space:]]+EXISTS[[:space:]]+)?([a-zA-Z_][a-zA-Z0-9_]*) ]]; then
      in_table=true
      table_name="${BASH_REMATCH[2]}"
      body=""
      continue
    fi
    if $in_table; then
      if [[ "$line" =~ ^\)\; ]]; then
        echo "TABLE:$table_name"
        echo "$body"
        echo "END_TABLE"
        in_table=false
      else
        if [[ -n "$body" ]]; then
          body="$body"$'\n'"$line"
        else
          body="$line"
        fi
      fi
    fi
  done < "$schema_file"
}

# Extract new CREATE VIEW, CREATE INDEX, CREATE TABLE statements from new schema
# that don't exist in old schema
extract_new_statements() {
  local old_file="$1"
  local new_file="$2"
  local stmt_type="$3"  # TABLE, VIEW, INDEX

  local new_stmts old_stmts
  case "$stmt_type" in
    TABLE)
      new_stmts=$(grep -oE 'CREATE TABLE (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$new_file" 2>/dev/null | awk '{print $NF}' || true)
      old_stmts=$(grep -oE 'CREATE TABLE (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$old_file" 2>/dev/null | awk '{print $NF}' || true)
      ;;
    VIEW)
      new_stmts=$(grep -oE 'CREATE VIEW (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$new_file" 2>/dev/null | awk '{print $NF}' || true)
      old_stmts=$(grep -oE 'CREATE VIEW (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$old_file" 2>/dev/null | awk '{print $NF}' || true)
      ;;
    INDEX)
      new_stmts=$(grep -oE 'CREATE INDEX (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$new_file" 2>/dev/null | awk '{print $NF}' || true)
      old_stmts=$(grep -oE 'CREATE INDEX (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$old_file" 2>/dev/null | awk '{print $NF}' || true)
      ;;
  esac

  # Find names in new but not in old
  local name
  for name in $new_stmts; do
    if ! echo "$old_stmts" | grep -qx "$name" 2>/dev/null; then
      echo "$name"
    fi
  done
}

# Get next migration number (zero-padded to 3 digits)
next_migration_number() {
  local migrations_dir="$1"
  local max_num=0

  if [[ -d "$migrations_dir" ]]; then
    local f
    for f in "$migrations_dir"/*.sql; do
      [[ -e "$f" ]] || continue
      local basename_f
      basename_f=$(basename "$f")
      local num
      num=$(echo "$basename_f" | grep -oE '^[0-9]+' || true)
      if [[ -n "$num" ]] && [[ "$((10#$num))" -gt "$max_num" ]]; then
        max_num=$((10#$num))
      fi
    done
  fi

  printf '%03d' $((max_num + 1))
}

# Extract a full statement block (CREATE TABLE/VIEW/INDEX) from a schema file by name
extract_statement_block() {
  local schema_file="$1"
  local stmt_type="$2"   # TABLE, VIEW, INDEX
  local name="$3"

  case "$stmt_type" in
    TABLE)
      # Extract from CREATE TABLE to );
      awk "/CREATE TABLE.*${name}/,/^\\);/" "$schema_file"
      ;;
    VIEW)
      # Views may have DROP VIEW before CREATE VIEW — grab both
      awk "/DROP VIEW.*${name}/,/;/" "$schema_file"
      echo ""
      awk "/CREATE VIEW.*${name}/,/;/" "$schema_file"
      ;;
    INDEX)
      grep "CREATE INDEX.*${name}" "$schema_file"
      ;;
  esac
}

generate_migration() {
  local project_path="$1"
  local old_schema="$2"
  local new_schema="$3"
  local migrations_dir="$project_path/.pm/migrations"

  if [[ -z "$old_schema" ]] || [[ -z "$new_schema" ]]; then
    log_error "Usage: n2o migrate --generate <project-path> --old <old.sql> --new <new.sql>"
    exit 1
  fi

  if [[ ! -f "$old_schema" ]]; then
    log_error "Old schema file not found: $old_schema"
    exit 1
  fi

  if [[ ! -f "$new_schema" ]]; then
    log_error "New schema file not found: $new_schema"
    exit 1
  fi

  mkdir -p "$migrations_dir"

  local migration_sql=""

  # 1. Diff columns in existing tables (ADD/DROP COLUMN)
  local old_tables new_tables
  old_tables=$(extract_tables "$old_schema")
  new_tables=$(extract_tables "$new_schema")

  # Build list of table names from old schema
  local old_table_names
  old_table_names=$(echo "$old_tables" | grep '^TABLE:' | sed 's/^TABLE://')

  # For each table that exists in both old and new, diff columns
  local tname
  for tname in $old_table_names; do
    # Check if table also exists in new
    if ! echo "$new_tables" | grep -q "^TABLE:$tname$"; then
      continue
    fi

    # Get old columns
    local old_body new_body
    old_body=$(echo "$old_tables" | awk "/^TABLE:${tname}$/,/^END_TABLE$/" | grep -v "^TABLE:" | grep -v "^END_TABLE$")
    new_body=$(echo "$new_tables" | awk "/^TABLE:${tname}$/,/^END_TABLE$/" | grep -v "^TABLE:" | grep -v "^END_TABLE$")

    local old_cols new_cols
    old_cols=$(parse_table_columns "$old_body")
    new_cols=$(parse_table_columns "$new_body")

    local old_col_names new_col_names
    old_col_names=$(echo "$old_cols" | awk -F'\t' '{print $1}' | grep -v '^$' || true)
    new_col_names=$(echo "$new_cols" | awk -F'\t' '{print $1}' | grep -v '^$' || true)

    # Added columns (in new but not in old)
    local col
    for col in $new_col_names; do
      if ! echo "$old_col_names" | grep -qx "$col" 2>/dev/null; then
        # Get full definition
        local col_def
        col_def=$(echo "$new_cols" | awk -F'\t' -v c="$col" '$1 == c {print $2}')
        migration_sql="${migration_sql}ALTER TABLE $tname ADD COLUMN $col_def;"$'\n'
      fi
    done

    # Dropped columns (in old but not in new)
    for col in $old_col_names; do
      if ! echo "$new_col_names" | grep -qx "$col" 2>/dev/null; then
        migration_sql="${migration_sql}ALTER TABLE $tname DROP COLUMN $col;"$'\n'
      fi
    done
  done

  # 2. New tables (in new but not in old)
  local new_table_names
  new_table_names=$(extract_new_statements "$old_schema" "$new_schema" "TABLE")
  for tname in $new_table_names; do
    local block
    block=$(extract_statement_block "$new_schema" "TABLE" "$tname")
    migration_sql="${migration_sql}${block}"$'\n'
  done

  # 3. New views (in new but not in old)
  local new_view_names
  new_view_names=$(extract_new_statements "$old_schema" "$new_schema" "VIEW")
  for tname in $new_view_names; do
    local block
    block=$(extract_statement_block "$new_schema" "VIEW" "$tname")
    migration_sql="${migration_sql}${block}"$'\n'
  done

  # 4. New indexes (in new but not in old)
  local new_index_names
  new_index_names=$(extract_new_statements "$old_schema" "$new_schema" "INDEX")
  for tname in $new_index_names; do
    local block
    block=$(extract_statement_block "$new_schema" "INDEX" "$tname")
    migration_sql="${migration_sql}${block}"$'\n'
  done

  # Check if there are any changes
  local trimmed_sql
  trimmed_sql=$(echo "$migration_sql" | sed '/^$/d' | sed 's/^[[:space:]]*//')
  if [[ -z "$trimmed_sql" ]]; then
    log_info "No schema changes detected."
    return 0
  fi

  # Write migration file
  local num
  num=$(next_migration_number "$migrations_dir")
  local migration_file="$migrations_dir/${num}-auto-generated.sql"
  echo "-- Auto-generated migration" > "$migration_file"
  echo "-- Generated at: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$migration_file"
  echo "" >> "$migration_file"
  echo "$migration_sql" >> "$migration_file"

  log_success "Generated migration: $(basename "$migration_file")"
  log_info "Review the migration before applying:"
  log_info "  cat $migration_file"
}

# =============================================================================
# MAIN
# =============================================================================

main() {
  check_deps

  local command="${1:-}"
  shift 2>/dev/null || true

  case "$command" in
    init)
      cmd_init "$@"
      ;;
    pin)
      cmd_pin "$@"
      ;;
    sync)
      cmd_sync "$@"
      ;;
    migrate)
      cmd_migrate "$@"
      ;;
    check)
      cmd_check "$@"
      ;;
    stats)
      cmd_stats "$@"
      ;;
    version|--version|-v)
      if [[ "${1:-}" == "bump" ]]; then
        shift
        cmd_version_bump "$@"
      else
        echo "n2o v$VERSION"
      fi
      ;;
    help|--help|-h|"")
      echo "n2o — N2O Workflow Framework CLI (v$VERSION)"
      echo ""
      echo "Usage:"
      echo "  n2o init <project-path> [--interactive] [--register]"
      echo "      Bootstrap a new project with N2O workflow files."
      echo ""
      echo "  n2o sync <project-path> [--dry-run] [--force] [--only=agents,patterns,schema,scripts]"
      echo "      Push framework updates to a project."
      echo ""
      echo "  n2o sync --all [--dry-run] [--force]"
      echo "      Push framework updates to all registered projects."
      echo ""
      echo "  n2o pin <project-path> [<version>]"
      echo "      Pin a project to a framework version. Sync will skip pinned projects."
      echo ""
      echo "  n2o pin <project-path> --unpin"
      echo "      Remove version pin, allowing sync to update to latest."
      echo ""
      echo "  n2o migrate --apply <project-path>"
      echo "      Apply pending schema migrations to a project's tasks.db."
      echo ""
      echo "  n2o migrate --status <project-path>"
      echo "      Show applied and pending migrations for a project."
      echo ""
      echo "  n2o migrate --generate <project-path>"
      echo "      Auto-generate a migration by diffing schema.sql changes."
      echo ""
      echo "  n2o check <project-path>"
      echo "      Run health check on an initialized project."
      echo ""
      echo "  n2o stats [--json]"
      echo "      Show project statistics: sessions, tool usage, sprint progress."
      echo ""
      echo "  n2o version"
      echo "      Print the current framework version."
      echo ""
      echo "  n2o version bump [patch|minor|major]"
      echo "      Bump framework version, generate changelog from git log, create git tag."
      echo ""
      echo "  n2o help"
      echo "      Show this help message."
      ;;
    *)
      log_error "Unknown command: $command"
      echo "Run 'n2o help' for usage."
      exit 1
      ;;
  esac
}

main "$@"
