#!/bin/bash
set -e

# =============================================================================
# n2o — N2O Workflow Framework CLI
# Usage:
#   n2o setup [--framework-path <path>] [--no-auto-sync] [--auto-pull] [--name <name>]
#   n2o init <project-path> [--interactive] [--register]
#   n2o sync <project-path> [--dry-run] [--force] [--quiet] [--only=...]
#   n2o sync --all [--dry-run] [--force]
#   n2o sync --pull-tasks
#   n2o pin <project-path> [<version>] [--unpin]
#   n2o check <project-path>
#   n2o stats [--json] [--compare <skill-name>]
# =============================================================================

N2O_DIR="$(cd "$(dirname "$0")" && pwd)"
MANIFEST="$N2O_DIR/n2o-manifest.json"
PROJECTS_FILE="$N2O_DIR/.n2o-projects.json"
VERSION=$(jq -r '.version' "$MANIFEST")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

log_info()    { echo -e "${BLUE}ℹ${NC}  $1"; }
log_success() { echo -e "${GREEN}✓${NC}  $1"; }
log_warn()    { echo -e "${YELLOW}⚠${NC}  $1"; }
log_error()   { echo -e "${RED}✗${NC}  $1" >&2; }
log_header()  { echo -e "\n${BOLD}$1${NC}"; }

# Resolve the project tasks.db by walking up from CWD.
# Falls back to $N2O_DIR/.pm/tasks.db if no project DB found.
resolve_project_db() {
  local search_dir="$PWD"
  while [[ "$search_dir" != "/" ]]; do
    if [[ -f "$search_dir/.pm/tasks.db" ]]; then
      echo "$search_dir/.pm/tasks.db"
      return
    fi
    search_dir="$(dirname "$search_dir")"
  done
  echo "$N2O_DIR/.pm/tasks.db"
}

# Compare two semver strings. Returns via exit code:
#   0 = $1 > $2 (first is greater)
#   1 = $1 = $2 (equal)
#   2 = $1 < $2 (first is lesser)
version_compare() {
  local v1="$1" v2="$2"
  if [[ "$v1" == "$v2" ]]; then return 1; fi
  local IFS=.
  local i v1_parts=($v1) v2_parts=($v2)
  for ((i=0; i<3; i++)); do
    local a="${v1_parts[i]:-0}" b="${v2_parts[i]:-0}"
    if ((a > b)); then return 0; fi
    if ((a < b)); then return 2; fi
  done
  return 1
}

# Display changelog entries between two versions
show_changelog() {
  local from_version="$1"
  local to_version="$2"
  local changelog="$N2O_DIR/CHANGELOG.md"

  if [[ ! -f "$changelog" ]]; then
    return
  fi

  # Don't show if versions are the same
  if [[ "$from_version" == "$to_version" ]]; then
    return
  fi

  log_header "What's new ($from_version → $to_version)"

  local in_range=false
  while IFS= read -r line; do
    if [[ "$line" =~ ^##[[:space:]]+([0-9]+\.[0-9]+\.[0-9]+) ]]; then
      local ver="${BASH_REMATCH[1]}"
      if [[ "$ver" == "$to_version" ]]; then
        in_range=true
        continue  # Skip the version header itself
      elif [[ "$ver" == "$from_version" ]]; then
        in_range=false
        break
      fi
    fi
    if $in_range && [[ -n "$line" ]] && [[ ! "$line" =~ ^# ]]; then
      echo "  $line"
    fi
  done < "$changelog"
}

# Bump version in manifest. $1 = patch|minor|major
bump_version() {
  local level="${1:-patch}"
  local current="$VERSION"
  local IFS=.
  local parts=($current)
  local major="${parts[0]}" minor="${parts[1]}" patch="${parts[2]}"

  case "$level" in
    patch) ((patch++)) ;;
    minor) ((minor++)); patch=0 ;;
    major) ((major++)); minor=0; patch=0 ;;
    *) log_error "Invalid bump level: $level. Use patch, minor, or major."; return 1 ;;
  esac

  local new_version="$major.$minor.$patch"
  local tmp
  tmp=$(mktemp)
  jq --arg v "$new_version" '.version = $v' "$MANIFEST" > "$tmp"
  mv "$tmp" "$MANIFEST"

  # Update the global VERSION variable
  VERSION="$new_version"
  log_success "Version bumped: $current → $new_version"
}

# Auto-generate a changelog entry from git log since last tag
generate_changelog_entry() {
  local new_version="$1"
  local changelog="$N2O_DIR/CHANGELOG.md"

  # Find the last version tag
  local last_tag
  last_tag=$(git -C "$N2O_DIR" describe --tags --abbrev=0 2>/dev/null || echo "")

  local log_range=""
  if [[ -n "$last_tag" ]]; then
    log_range="$last_tag..HEAD"
  fi

  # Get commit messages
  local commits
  commits=$(git -C "$N2O_DIR" log $log_range --oneline --no-decorate 2>/dev/null || echo "")

  if [[ -z "$commits" ]]; then
    commits="- No commits since last version"
  else
    # Format as bullet points
    commits=$(echo "$commits" | sed 's/^[a-f0-9]* /- /')
  fi

  # Build the new entry
  local entry
  entry=$(printf "## %s\n\n%s\n" "$new_version" "$commits")

  # Prepend to CHANGELOG.md
  if [[ -f "$changelog" ]]; then
    local existing
    existing=$(cat "$changelog")
    # Insert after the first line (the # N2O Changelog header)
    local header
    header=$(head -1 "$changelog")
    local rest
    rest=$(tail -n +2 "$changelog")
    printf "%s\n\n%s\n%s" "$header" "$entry" "$rest" > "$changelog"
  else
    printf "# N2O Changelog\n\n%s\n" "$entry" > "$changelog"
  fi

  log_success "Generated changelog entry for v$new_version"
}

# Handle 'n2o version bump [patch|minor|major]'
cmd_version_bump() {
  local level="${1:-patch}"

  bump_version "$level"
  generate_changelog_entry "$VERSION"

  # Create git tag
  if git -C "$N2O_DIR" tag "v$VERSION" 2>/dev/null; then
    log_success "Created git tag: v$VERSION"
  else
    log_warn "Could not create git tag v$VERSION (may already exist)"
  fi

  echo ""
  log_info "Review CHANGELOG.md, then commit and run 'n2o sync --all'"
}

# Check if a sync category should be included
should_sync_category() {
  local category="$1"
  local filter="$2"
  # If no filter, sync everything
  [[ -z "$filter" ]] && return 0
  # Check if category is in comma-separated list
  [[ ",$filter," == *",$category,"* ]]
}

# Validate sync category names
validate_sync_categories() {
  local categories="$1"
  local valid="agents,patterns,schema,scripts"
  local IFS=','
  local cats=($categories)
  for cat in "${cats[@]}"; do
    if [[ ",$valid," != *",$cat,"* ]]; then
      log_error "Unknown sync category: '$cat'. Valid categories: agents, patterns, schema, scripts"
      exit 1
    fi
  done
}

# Register or merge the N2O hooks into .claude/settings.json
# Registers both SessionStart (for session init) and SessionEnd (for transcript collection)
register_session_hook() {
  local project_path="$1"
  local settings_file="$project_path/.claude/settings.json"

  local start_entry='{"matcher":"startup","hooks":[{"type":"command","command":"bash \"$CLAUDE_PROJECT_DIR/scripts/n2o-session-hook.sh\"","timeout":5}]}'
  local end_entry='{"matcher":"","hooks":[{"type":"command","command":"bash \"$CLAUDE_PROJECT_DIR/scripts/collect-transcripts.sh\" --quiet","timeout":30}]}'

  if [[ ! -f "$settings_file" ]]; then
    # Create fresh settings with both hooks
    jq -n \
      --argjson start "$start_entry" \
      --argjson end "$end_entry" \
      '{"hooks":{"SessionStart":[$start],"SessionEnd":[$end]}}' > "$settings_file"
    log_success "Created .claude/settings.json with SessionStart + SessionEnd hooks"
    return
  fi

  local tmp
  tmp=$(mktemp)
  local changed=false

  # Ensure SessionStart hook
  if ! jq -e '.hooks.SessionStart[]?.hooks[]? | select(.command | test("n2o-session-hook"))' "$settings_file" &>/dev/null; then
    if jq -e '.hooks.SessionStart' "$settings_file" &>/dev/null; then
      jq --argjson entry "$start_entry" '.hooks.SessionStart += [$entry]' "$settings_file" > "$tmp"
    elif jq -e '.hooks' "$settings_file" &>/dev/null; then
      jq --argjson entry "$start_entry" '.hooks.SessionStart = [$entry]' "$settings_file" > "$tmp"
    else
      jq --argjson entry "$start_entry" '.hooks = {"SessionStart": [$entry]}' "$settings_file" > "$tmp"
    fi
    mv "$tmp" "$settings_file"
    changed=true
    log_success "Added SessionStart hook"
  fi

  # Ensure SessionEnd hook (for transcript collection)
  if ! jq -e '.hooks.SessionEnd[]?.hooks[]? | select(.command | test("collect-transcripts"))' "$settings_file" &>/dev/null; then
    tmp=$(mktemp)
    if jq -e '.hooks.SessionEnd' "$settings_file" &>/dev/null; then
      jq --argjson entry "$end_entry" '.hooks.SessionEnd += [$entry]' "$settings_file" > "$tmp"
    elif jq -e '.hooks' "$settings_file" &>/dev/null; then
      jq --argjson entry "$end_entry" '.hooks.SessionEnd = [$entry]' "$settings_file" > "$tmp"
    else
      jq --argjson entry "$end_entry" '.hooks = {"SessionEnd": [$entry]}' "$settings_file" > "$tmp"
    fi
    mv "$tmp" "$settings_file"
    changed=true
    log_success "Added SessionEnd hook (transcript collection)"
  fi

  if ! $changed; then
    log_info "All hooks already registered"
  fi
}

check_deps() {
  for cmd in jq sqlite3; do
    if ! command -v "$cmd" &>/dev/null; then
      log_error "Required dependency '$cmd' not found. Please install it."
      exit 1
    fi
  done
}

# Check if a path matches any pattern in a JSON array field from the manifest.
# Uses simple glob matching (** means recursive).
is_project_file() {
  local rel_path="$1"
  local patterns
  patterns=$(jq -r '.project_files[]' "$MANIFEST")
  while IFS= read -r pattern; do
    # Convert glob pattern to a simple check
    # Remove trailing **
    local prefix="${pattern%%/\*\*}"
    if [[ "$prefix" != "$pattern" ]]; then
      # Pattern ends with /**, match anything under that prefix
      if [[ "$rel_path" == "$prefix"/* || "$rel_path" == "$prefix" ]]; then
        return 0
      fi
    else
      # Exact match
      if [[ "$rel_path" == "$pattern" ]]; then
        return 0
      fi
    fi
  done <<< "$patterns"
  return 1
}

# Get the list of framework source directories/files from the manifest
get_framework_sources() {
  jq -r '.framework_files[]' "$MANIFEST"
}

# Replace template placeholders in a file
fill_template() {
  local file="$1"
  local project_name="$2"
  local test_cmd="$3"
  local typecheck_cmd="$4"
  local lint_cmd="$5"
  local build_cmd="$6"

  sed -i '' \
    -e "s|{{project_name}}|${project_name}|g" \
    -e "s|{{test_command}}|${test_cmd}|g" \
    -e "s|{{typecheck_command}}|${typecheck_cmd}|g" \
    -e "s|{{lint_command}}|${lint_cmd}|g" \
    -e "s|{{build_command}}|${build_cmd}|g" \
    "$file"
}

# -----------------------------------------------------------------------------
# Migration helpers
# -----------------------------------------------------------------------------

# Compute SHA256 checksum of a file
file_checksum() {
  shasum -a 256 "$1" | awk '{print $1}'
}

# Apply pending migrations to a project's tasks.db
# Usage: apply_migrations <project_path>
apply_migrations() {
  local project_path="$1"
  local db="$project_path/.pm/tasks.db"
  local migrations_dir="$project_path/.pm/migrations"
  local applied=0

  if [[ ! -d "$migrations_dir" ]]; then
    return 0
  fi

  # List migration files sorted numerically
  local migration_files
  migration_files=$(find "$migrations_dir" -maxdepth 1 -name '*.sql' -type f 2>/dev/null | sort)

  if [[ -z "$migration_files" ]]; then
    return 0
  fi

  # Ensure _migrations table exists (for databases created before migration support)
  sqlite3 "$db" "CREATE TABLE IF NOT EXISTS _migrations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,
    applied_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    framework_version TEXT,
    checksum TEXT
  );" 2>/dev/null

  while IFS= read -r migration_file; do
    local name
    name=$(basename "$migration_file" .sql)

    # Skip if already applied
    local already_applied
    already_applied=$(sqlite3 "$db" "SELECT COUNT(*) FROM _migrations WHERE name='$name';" 2>/dev/null)
    if [[ "$already_applied" == "1" ]]; then
      continue
    fi

    # Apply the migration
    if sqlite3 "$db" < "$migration_file" 2>/dev/null; then
      local checksum
      checksum=$(file_checksum "$migration_file")
      sqlite3 "$db" "INSERT INTO _migrations (name, framework_version, checksum) VALUES ('$name', '$VERSION', '$checksum');"
      log_success "Applied migration: $name"
      ((applied++)) || true
    else
      log_error "Migration failed: $name"
      return 1
    fi
  done <<< "$migration_files"

  if [[ $applied -eq 0 ]]; then
    log_info "No pending migrations"
  else
    log_success "Applied $applied migration(s)"
  fi
}

# Seed _migrations table with all existing migration files (for fresh installs)
# Marks them as applied without running them (the fresh schema already has their changes)
seed_migrations() {
  local project_path="$1"
  local db="$project_path/.pm/tasks.db"
  local migrations_dir="$project_path/.pm/migrations"

  if [[ ! -d "$migrations_dir" ]]; then
    return 0
  fi

  local migration_files
  migration_files=$(find "$migrations_dir" -maxdepth 1 -name '*.sql' -type f 2>/dev/null | sort)

  if [[ -z "$migration_files" ]]; then
    return 0
  fi

  while IFS= read -r migration_file; do
    local name
    name=$(basename "$migration_file" .sql)
    local checksum
    checksum=$(file_checksum "$migration_file")
    sqlite3 "$db" "INSERT OR IGNORE INTO _migrations (name, framework_version, checksum) VALUES ('$name', '$VERSION', '$checksum');" 2>/dev/null
  done <<< "$migration_files"
}

# Register a project path in .n2o-projects.json
register_project() {
  local project_path="$1"
  
  if [[ ! -f "$PROJECTS_FILE" ]]; then
    echo '{"projects":[]}' > "$PROJECTS_FILE"
  fi

  # Check if already registered
  if jq -e --arg p "$project_path" '.projects | index($p)' "$PROJECTS_FILE" &>/dev/null; then
    log_info "Project already registered: $project_path"
    return 0
  fi

  # Add to registry
  local tmp
  tmp=$(mktemp)
  jq --arg p "$project_path" '.projects += [$p]' "$PROJECTS_FILE" > "$tmp"
  mv "$tmp" "$PROJECTS_FILE"
  log_success "Registered project: $project_path"
}

# Detect project type from package.json etc.
detect_project() {
  local project_path="$1"
  
  PROJECT_TYPE="unknown"
  PKG_MANAGER=""
  DEFAULT_TEST=""
  DEFAULT_TYPECHECK=""
  DEFAULT_LINT=""
  DEFAULT_BUILD=""

  if [[ -f "$project_path/package.json" ]]; then
    PROJECT_TYPE="node"
    
    # Detect package manager
    if [[ -f "$project_path/pnpm-lock.yaml" ]]; then
      PKG_MANAGER="pnpm"
    elif [[ -f "$project_path/yarn.lock" ]]; then
      PKG_MANAGER="yarn"
    elif [[ -f "$project_path/bun.lockb" ]]; then
      PKG_MANAGER="bun"
    else
      PKG_MANAGER="npm"
    fi

    # Read scripts from package.json to set defaults
    local scripts
    scripts=$(jq -r '.scripts // {}' "$project_path/package.json" 2>/dev/null || echo '{}')
    
    if echo "$scripts" | jq -e '.test' &>/dev/null; then
      DEFAULT_TEST="$PKG_MANAGER test"
    fi
    if echo "$scripts" | jq -e '.typecheck' &>/dev/null; then
      DEFAULT_TYPECHECK="$PKG_MANAGER typecheck"
    elif echo "$scripts" | jq -e '."typecheck:all"' &>/dev/null; then
      DEFAULT_TYPECHECK="$PKG_MANAGER typecheck:all"
    fi
    if echo "$scripts" | jq -e '.lint' &>/dev/null; then
      DEFAULT_LINT="$PKG_MANAGER lint"
    elif echo "$scripts" | jq -e '."lint:all"' &>/dev/null; then
      DEFAULT_LINT="$PKG_MANAGER lint:all"
    fi
    if echo "$scripts" | jq -e '.build' &>/dev/null; then
      DEFAULT_BUILD="$PKG_MANAGER build"
    fi
  elif [[ -f "$project_path/Cargo.toml" ]]; then
    PROJECT_TYPE="rust"
    PKG_MANAGER="cargo"
    DEFAULT_TEST="cargo test"
    DEFAULT_BUILD="cargo build"
    DEFAULT_LINT="cargo clippy"
  elif [[ -f "$project_path/pyproject.toml" ]] || [[ -f "$project_path/setup.py" ]]; then
    PROJECT_TYPE="python"
    DEFAULT_TEST="pytest"
    DEFAULT_LINT="ruff check"
  elif [[ -f "$project_path/go.mod" ]]; then
    PROJECT_TYPE="go"
    DEFAULT_TEST="go test ./..."
    DEFAULT_BUILD="go build ./..."
    DEFAULT_LINT="golangci-lint run"
  fi
}

# Prompt user for a value with a default
prompt_value() {
  local prompt="$1"
  local default="$2"
  local result

  if [[ -n "$default" ]]; then
    read -rp "  $prompt [$default]: " result
    echo "${result:-$default}"
  else
    read -rp "  $prompt: " result
    echo "$result"
  fi
}

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------

run_health_check() {
  local project_path="$1"
  local pass=0
  local fail=0

  check_pass() { echo -e "  ${GREEN}PASS${NC}  $1"; ((pass++)) || true; }
  check_fail() { echo -e "  ${RED}FAIL${NC}  $1"; ((fail++)) || true; }
  check_warn() { echo -e "  ${YELLOW}WARN${NC}  $1"; }

  log_header "Machine Prerequisites"

  # Check required dependencies
  for cmd in jq sqlite3 git; do
    if command -v "$cmd" &>/dev/null; then
      local ver
      ver=$("$cmd" --version 2>&1 | head -1)
      check_pass "$cmd installed ($ver)"
    else
      check_fail "$cmd not found — install it"
    fi
  done

  # Check bash version (need >=3.2 for associative-array-free scripts)
  local bash_major bash_minor
  bash_major="${BASH_VERSINFO[0]:-0}"
  bash_minor="${BASH_VERSINFO[1]:-0}"
  if [[ "$bash_major" -gt 3 ]] || [[ "$bash_major" -eq 3 && "$bash_minor" -ge 2 ]]; then
    check_pass "bash ${BASH_VERSION} (>=3.2)"
  else
    check_fail "bash ${BASH_VERSION} is too old (need >=3.2)"
  fi

  # Check Claude Code CLI
  if command -v claude &>/dev/null; then
    check_pass "claude CLI installed"
  else
    check_warn "claude CLI not found (optional — install Claude Code)"
  fi

  log_header "Health Check"

  # 1. Config valid JSON
  if jq '.' "$project_path/.pm/config.json" &>/dev/null; then
    check_pass "config.json is valid JSON"
  else
    check_fail "config.json is invalid JSON"
  fi

  # 2. Required config fields
  for field in n2o_version project_name developer_name; do
    local val
    val=$(jq -r ".$field // \"\"" "$project_path/.pm/config.json" 2>/dev/null)
    if [[ -n "$val" && "$val" != "null" ]]; then
      check_pass "config.$field = $val"
    else
      check_fail "config.$field is missing"
    fi
  done

  # 3. Commands object exists
  if jq -e '.commands' "$project_path/.pm/config.json" &>/dev/null; then
    check_pass "config.commands present"
  else
    check_fail "config.commands missing"
  fi

  # 4. Database exists and is valid
  if [[ -f "$project_path/.pm/tasks.db" ]] && sqlite3 "$project_path/.pm/tasks.db" "SELECT 1;" &>/dev/null; then
    check_pass "tasks.db exists and is valid"
  else
    check_fail "tasks.db missing or corrupt"
  fi

  # 5. Core tables
  for table in tasks developers task_dependencies; do
    local result
    result=$(sqlite3 "$project_path/.pm/tasks.db" "SELECT name FROM sqlite_master WHERE type='table' AND name='$table';" 2>/dev/null)
    if [[ "$result" == "$table" ]]; then
      check_pass "Table: $table"
    else
      check_fail "Missing table: $table"
    fi
  done

  # 6. Core views
  for view in available_tasks sprint_progress blocked_tasks; do
    local result
    result=$(sqlite3 "$project_path/.pm/tasks.db" "SELECT name FROM sqlite_master WHERE type='view' AND name='$view';" 2>/dev/null)
    if [[ "$result" == "$view" ]]; then
      check_pass "View: $view"
    else
      check_fail "Missing view: $view"
    fi
  done

  # 7. Schema exists
  if [[ -f "$project_path/.pm/schema.sql" ]]; then
    check_pass "schema.sql exists"
  else
    check_fail "schema.sql missing"
  fi

  # 8. Skill directories and SKILL.md files
  for skill in pm-agent tdd-agent bug-workflow detect-project react-best-practices web-design-guidelines; do
    if [[ -d "$project_path/.claude/skills/$skill" ]]; then
      if [[ -f "$project_path/.claude/skills/$skill/SKILL.md" ]]; then
        check_pass "Skill: $skill"
      else
        check_fail "Missing SKILL.md in $skill"
      fi
    else
      check_fail "Missing skill directory: $skill"
    fi
  done

  # 9. Scripts executable
  local non_exec_count=0
  while IFS= read -r script; do
    if [[ ! -x "$script" ]]; then
      check_fail "Not executable: ${script#$project_path/}"
      ((non_exec_count++)) || true
    fi
  done < <(find "$project_path/scripts" -name "*.sh" -type f 2>/dev/null)
  if [[ $non_exec_count -eq 0 ]]; then
    check_pass "All scripts executable"
  fi

  # 10. Gitignore entries
  if [[ -f "$project_path/.gitignore" ]]; then
    local gitignore_ok=true
    for entry in ".pm/tasks.db" ".n2o-backup/"; do
      if ! grep -qF "$entry" "$project_path/.gitignore" 2>/dev/null; then
        check_fail "Missing from .gitignore: $entry"
        gitignore_ok=false
      fi
    done
    if $gitignore_ok; then
      check_pass "Gitignore entries present"
    fi
  else
    check_fail ".gitignore missing"
  fi

  # 11. Session hooks in settings.json
  local settings_file="$project_path/.claude/settings.json"
  if [[ -f "$settings_file" ]]; then
    if jq -e '.hooks.SessionStart' "$settings_file" &>/dev/null; then
      check_pass "SessionStart hook configured"
    else
      check_fail "SessionStart hook missing in settings.json"
    fi
    if jq -e '.hooks.SessionEnd' "$settings_file" &>/dev/null; then
      check_pass "SessionEnd hook configured"
    else
      check_fail "SessionEnd hook missing in settings.json"
    fi
  else
    check_fail ".claude/settings.json missing (no session hooks)"
  fi

  # 12. rates.json exists
  if [[ -f "$project_path/.pm/rates.json" ]] || [[ -f "$project_path/templates/rates.json" ]]; then
    check_pass "rates.json exists"
  else
    check_fail "rates.json missing (not in .pm/ or templates/)"
  fi

  # 13. Workflow tables (transcripts + workflow_events)
  for table in transcripts workflow_events; do
    local result
    result=$(sqlite3 "$project_path/.pm/tasks.db" "SELECT name FROM sqlite_master WHERE type='table' AND name='$table';" 2>/dev/null)
    if [[ "$result" == "$table" ]]; then
      check_pass "Table: $table"
    else
      check_fail "Missing table: $table"
    fi
  done

  # Summary
  echo ""
  local total=$((pass + fail))
  if [[ $fail -eq 0 ]]; then
    log_success "All $total checks passed"
    return 0
  else
    log_error "$fail of $total checks failed"
    return 1
  fi
}

cmd_check() {
  local project_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -*) log_error "Unknown option: $1"; exit 1 ;;
      *)  project_path="$1"; shift ;;
    esac
  done

  if [[ -z "$project_path" ]]; then
    log_error "Usage: n2o check <project-path>"
    exit 1
  fi

  project_path="$(cd "$project_path" && pwd)"

  if [[ ! -f "$project_path/.pm/config.json" ]]; then
    log_error "Not an N2O project (missing .pm/config.json). Run 'n2o init' first."
    exit 1
  fi

  run_health_check "$project_path"
}

# =============================================================================
# SETUP COMMAND — first-time developer config
# =============================================================================

GLOBAL_CONFIG_DIR="$HOME/.n2o"
GLOBAL_CONFIG="$GLOBAL_CONFIG_DIR/config.json"

cmd_setup() {
  local framework_path=""
  local auto_sync=""
  local auto_pull=""
  local dev_name=""
  local non_interactive=false

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --framework-path) framework_path="$2"; shift 2 ;;
      --framework-path=*) framework_path="${1#--framework-path=}"; shift ;;
      --no-auto-sync) auto_sync="false"; non_interactive=true; shift ;;
      --auto-pull) auto_pull="true"; non_interactive=true; shift ;;
      --name) dev_name="$2"; shift 2 ;;
      --name=*) dev_name="${1#--name=}"; shift ;;
      -*) log_error "Unknown option: $1"; exit 1 ;;
      *) log_error "Unknown argument: $1"; exit 1 ;;
    esac
  done

  log_header "N2O Developer Setup"

  # If config exists, show current values
  if [[ -f "$GLOBAL_CONFIG" ]]; then
    log_info "Existing config found at $GLOBAL_CONFIG:"
    echo ""
    echo "  framework_path: $(jq -r '.framework_path // "(not set)"' "$GLOBAL_CONFIG")"
    echo "  auto_sync:      $(jq -r '.auto_sync // "(not set)"' "$GLOBAL_CONFIG")"
    echo "  auto_pull:      $(jq -r '.auto_pull // "(not set)"' "$GLOBAL_CONFIG")"
    echo "  developer_name: $(jq -r '.developer_name // "(not set)"' "$GLOBAL_CONFIG")"
    echo ""

    if ! $non_interactive && [[ -z "$framework_path" ]]; then
      read -rp "  Reconfigure? (y/N): " confirm
      if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "Keeping existing config."
        return 0
      fi
    fi
  fi

  # 1. Framework path
  if [[ -z "$framework_path" ]]; then
    if $non_interactive; then
      framework_path="$N2O_DIR"
    else
      framework_path=$(prompt_value "Framework path" "$N2O_DIR")
    fi
  fi

  # Resolve to absolute path
  framework_path="$(cd "$framework_path" 2>/dev/null && pwd || echo "$framework_path")"

  # Validate: n2o-manifest.json must exist
  if [[ ! -f "$framework_path/n2o-manifest.json" ]]; then
    log_error "Not an N2O framework directory (missing n2o-manifest.json): $framework_path"
    exit 1
  fi

  # Validate: must be a git repo
  if ! git -C "$framework_path" rev-parse --git-dir &>/dev/null 2>&1; then
    log_error "Not a git repository: $framework_path"
    exit 1
  fi

  # Validate git access (can we fetch?)
  log_info "Validating git access..."
  if git -C "$framework_path" ls-remote --exit-code origin &>/dev/null 2>&1; then
    log_success "Git access verified"
  else
    log_warn "Cannot reach remote (offline or no access). Continuing with local clone."
  fi

  # 2. Developer name
  if [[ -z "$dev_name" ]]; then
    local default_name
    default_name=$(git config user.name 2>/dev/null || echo "")
    if $non_interactive; then
      dev_name="$default_name"
    else
      dev_name=$(prompt_value "Developer name" "$default_name")
    fi
  fi

  # 3. Auto-sync preference
  if [[ -z "$auto_sync" ]]; then
    if $non_interactive; then
      auto_sync="true"
    else
      read -rp "  Enable auto-sync on session start? (Y/n): " ans
      if [[ "$ans" == "n" || "$ans" == "N" ]]; then
        auto_sync="false"
      else
        auto_sync="true"
      fi
    fi
  fi

  # 4. Auto-pull preference
  if [[ -z "$auto_pull" ]]; then
    if $non_interactive; then
      auto_pull="false"
    else
      echo ""
      log_info "Auto-pull runs 'git pull --ff-only' before syncing."
      log_info "Requires network — may exceed the 5s hook timeout on slow connections."
      read -rp "  Enable auto-pull? (y/N): " ans
      if [[ "$ans" == "y" || "$ans" == "Y" ]]; then
        auto_pull="true"
      else
        auto_pull="false"
      fi
    fi
  fi

  # 5. Write config
  mkdir -p "$GLOBAL_CONFIG_DIR"
  jq -n \
    --arg fp "$framework_path" \
    --argjson as "$auto_sync" \
    --argjson ap "$auto_pull" \
    --arg dn "$dev_name" \
    '{
      framework_path: $fp,
      auto_sync: $as,
      auto_pull: $ap,
      developer_name: $dn
    }' > "$GLOBAL_CONFIG"

  echo ""
  log_success "Config written to $GLOBAL_CONFIG"
  echo ""
  echo "  framework_path: $framework_path"
  echo "  auto_sync:      $auto_sync"
  echo "  auto_pull:      $auto_pull"
  echo "  developer_name: $dev_name"
  echo ""
  log_info "Projects will auto-sync from this framework on each Claude Code session start."
}

# =============================================================================
# INIT COMMAND
# =============================================================================

cmd_init() {
  local project_path=""
  local interactive=false
  local do_register=false

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --interactive) interactive=true; shift ;;
      --register)    do_register=true; shift ;;
      -*)            log_error "Unknown option: $1"; exit 1 ;;
      *)             project_path="$1"; shift ;;
    esac
  done

  if [[ -z "$project_path" ]]; then
    log_error "Usage: n2o init <project-path> [--interactive] [--register]"
    exit 1
  fi

  # Resolve to absolute path
  project_path="$(cd "$project_path" 2>/dev/null && pwd || { mkdir -p "$project_path" && cd "$project_path" && pwd; })"

  log_header "Initializing N2O workflow in: $project_path"

  # Check if already initialized
  if [[ -f "$project_path/.pm/config.json" ]]; then
    local existing_version
    existing_version=$(jq -r '.n2o_version // "unknown"' "$project_path/.pm/config.json")
    log_warn "Project already initialized (v$existing_version). Use 'n2o sync' to update framework files."
    read -rp "  Continue anyway? (y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
      exit 0
    fi
  fi

  # ---- Step 1: Create directory structure ----
  log_header "1. Creating directory structure"
  local dirs
  dirs=$(jq -r '.directory_structure[]' "$MANIFEST")
  while IFS= read -r dir; do
    if [[ ! -d "$project_path/$dir" ]]; then
      mkdir -p "$project_path/$dir"
      log_success "Created $dir/"
    else
      log_info "Exists: $dir/"
    fi
  done <<< "$dirs"

  # ---- Step 2: Copy framework files ----
  log_header "2. Copying framework files"

  # Skills → .claude/skills/
  if [[ -d "$N2O_DIR/02-agents" ]]; then
    cp -r "$N2O_DIR/02-agents/"* "$project_path/.claude/skills/" 2>/dev/null || true
    log_success "Copied agents → .claude/skills/"
  fi

  if [[ -d "$N2O_DIR/03-patterns" ]]; then
    # Copy pattern directories into skills
    cp -r "$N2O_DIR/03-patterns/"* "$project_path/.claude/skills/" 2>/dev/null || true
    log_success "Copied patterns → .claude/skills/"
  fi

  # Schema → .pm/schema.sql
  if [[ -f "$N2O_DIR/.pm/schema.sql" ]]; then
    cp "$N2O_DIR/.pm/schema.sql" "$project_path/.pm/schema.sql"
    log_success "Copied schema.sql → .pm/"
  fi

  # Migrations → .pm/migrations/
  if [[ -d "$N2O_DIR/.pm/migrations" ]]; then
    mkdir -p "$project_path/.pm/migrations"
    local migration_count=0
    while IFS= read -r f; do
      cp "$f" "$project_path/.pm/migrations/"
      ((migration_count++)) || true
    done < <(find "$N2O_DIR/.pm/migrations" -maxdepth 1 -name '*.sql' -type f 2>/dev/null)
    if [[ $migration_count -gt 0 ]]; then
      log_success "Copied $migration_count migration(s) → .pm/migrations/"
    fi
  fi

  # Scripts → scripts/
  if [[ -d "$N2O_DIR/scripts" ]]; then
    cp -r "$N2O_DIR/scripts/"* "$project_path/scripts/" 2>/dev/null || true
    # Make scripts executable
    find "$project_path/scripts" -name "*.sh" -exec chmod +x {} \;
    log_success "Copied scripts → scripts/"
  fi

  # Seed skill checksums for override protection
  local checksums_file="$project_path/.pm/.skill-checksums.json"
  echo '{}' > "$checksums_file"
  local checksum_count=0
  while IFS= read -r skill_file; do
    local rel="${skill_file#$project_path/.claude/skills/}"
    # Determine category from source directory
    local skill_dir="${rel%%/*}"
    local category=""
    if [[ -d "$N2O_DIR/02-agents/$skill_dir" ]]; then
      category="agents"
    elif [[ -d "$N2O_DIR/03-patterns/$skill_dir" ]]; then
      category="patterns"
    fi
    if [[ -n "$category" ]]; then
      set_stored_checksum "$checksums_file" "$category/$rel" "$(file_checksum "$skill_file")"
      ((checksum_count++)) || true
    fi
  done < <(find "$project_path/.claude/skills" -name "SKILL.md" -type f 2>/dev/null)
  if [[ $checksum_count -gt 0 ]]; then
    log_success "Seeded $checksum_count skill checksums for override protection"
  fi

  # ---- Step 3: Detect project & gather config ----
  log_header "3. Configuring project"
  detect_project "$project_path"

  local project_name
  project_name="$(basename "$project_path")"
  local test_cmd="$DEFAULT_TEST"
  local typecheck_cmd="$DEFAULT_TYPECHECK"
  local lint_cmd="$DEFAULT_LINT"
  local build_cmd="$DEFAULT_BUILD"

  if [[ "$PROJECT_TYPE" != "unknown" ]]; then
    log_info "Detected: $PROJECT_TYPE project (package manager: ${PKG_MANAGER:-none})"
  fi

  # Detect developer name from git config
  local developer_name=""
  developer_name=$(git config user.name 2>/dev/null || echo "")

  if $interactive; then
    log_info "Interactive mode — press Enter to accept defaults"
    project_name=$(prompt_value "Project name" "$project_name")
    developer_name=$(prompt_value "Developer name" "$developer_name")
    test_cmd=$(prompt_value "Test command" "$test_cmd")
    typecheck_cmd=$(prompt_value "Typecheck command" "$typecheck_cmd")
    lint_cmd=$(prompt_value "Lint command" "$lint_cmd")
    build_cmd=$(prompt_value "Build command" "$build_cmd")
  fi

  # ---- Step 4: Scaffold project files from templates ----
  log_header "4. Scaffolding project files"

  # config.json
  if [[ ! -f "$project_path/.pm/config.json" ]]; then
    cp "$N2O_DIR/templates/config.json" "$project_path/.pm/config.json"
    # Fill in detected/provided values
    local tmp
    tmp=$(mktemp)
    jq \
      --arg ver "$VERSION" \
      --arg name "$project_name" \
      --arg dev "$developer_name" \
      --arg test "$test_cmd" \
      --arg tc "$typecheck_cmd" \
      --arg lint "$lint_cmd" \
      --arg build "$build_cmd" \
      '.n2o_version = $ver | .project_name = $name | .developer_name = $dev | .commands.test = $test | .commands.typecheck = $tc | .commands.lint = $lint | .commands.build = $build' \
      "$project_path/.pm/config.json" > "$tmp"
    mv "$tmp" "$project_path/.pm/config.json"
    log_success "Created .pm/config.json"
  else
    log_info "Exists: .pm/config.json (skipped)"
  fi

  # CLAUDE.md
  if [[ ! -f "$project_path/CLAUDE.md" ]]; then
    cp "$N2O_DIR/templates/CLAUDE.md" "$project_path/CLAUDE.md"
    fill_template "$project_path/CLAUDE.md" "$project_name" "$test_cmd" "$typecheck_cmd" "$lint_cmd" "$build_cmd"
    log_success "Created CLAUDE.md (Claude will auto-detect project structure on first run)"
  else
    log_warn "Existing CLAUDE.md found. N2O needs its own CLAUDE.md for skill references and auto-invocation."
    echo ""
    echo "  [r] Replace — back up existing to CLAUDE.md.bak, install N2O template"
    echo "  [s] Skip    — keep your existing CLAUDE.md (you'll need to merge N2O sections manually)"
    echo ""
    local claude_choice=""
    read -rp "  Your choice [r/s]: " claude_choice
    case "$claude_choice" in
      r|R|replace)
        cp "$project_path/CLAUDE.md" "$project_path/CLAUDE.md.bak"
        cp "$N2O_DIR/templates/CLAUDE.md" "$project_path/CLAUDE.md"
        fill_template "$project_path/CLAUDE.md" "$project_name" "$test_cmd" "$typecheck_cmd" "$lint_cmd" "$build_cmd"
        log_success "Replaced CLAUDE.md (backup saved to CLAUDE.md.bak)"
        ;;
      *)
        log_info "Kept existing CLAUDE.md (skipped)"
        ;;
    esac
  fi

  # schema-extensions.sql
  if [[ ! -f "$project_path/.pm/schema-extensions.sql" ]]; then
    cp "$N2O_DIR/templates/schema-extensions.sql" "$project_path/.pm/schema-extensions.sql"
    log_success "Created .pm/schema-extensions.sql"
  else
    log_info "Exists: .pm/schema-extensions.sql (skipped)"
  fi

  # ---- Step 4b: Copy rates.json ----
  if [[ -f "$N2O_DIR/templates/rates.json" ]]; then
    cp "$N2O_DIR/templates/rates.json" "$project_path/.pm/rates.json"
    log_success "Copied rates.json → .pm/"
  fi

  # ---- Step 5: Initialize database ----
  log_header "5. Initializing task database"
  if [[ ! -f "$project_path/.pm/tasks.db" ]]; then
    sqlite3 "$project_path/.pm/tasks.db" < "$project_path/.pm/schema.sql"
    if [[ -f "$project_path/.pm/schema-extensions.sql" ]] && [[ -s "$project_path/.pm/schema-extensions.sql" ]]; then
      # Only run if file has actual SQL (not just comments)
      if grep -qE '^\s*(CREATE|ALTER|INSERT|DROP)' "$project_path/.pm/schema-extensions.sql" 2>/dev/null; then
        sqlite3 "$project_path/.pm/tasks.db" < "$project_path/.pm/schema-extensions.sql"
        log_success "Applied schema extensions"
      fi
    fi
    seed_migrations "$project_path"
    log_success "Created .pm/tasks.db"
  else
    log_info "Exists: .pm/tasks.db (skipped)"
  fi

  # ---- Step 6: Update .gitignore ----
  log_header "6. Updating .gitignore"
  local gitignore="$project_path/.gitignore"
  local entries=(".pm/tasks.db" ".wm/" ".env.local" ".n2o-backup/" ".pm/.last_seen_version" ".pm/.skill-checksums.json" ".worktrees/")

  if [[ ! -f "$gitignore" ]]; then
    touch "$gitignore"
  fi

  for entry in "${entries[@]}"; do
    if ! grep -qxF "$entry" "$gitignore" 2>/dev/null; then
      echo "$entry" >> "$gitignore"
      log_success "Added '$entry' to .gitignore"
    fi
  done

  # ---- Step 7: Generate config helper script ----
  log_header "7. Generating config helper"
  cat > "$project_path/scripts/n2o-config.sh" <<'HELPER'
#!/bin/bash
# Auto-generated by n2o init — sources project config for use in skills/scripts.
# Usage: source scripts/n2o-config.sh

_N2O_CONFIG=".pm/config.json"

if [[ ! -f "$_N2O_CONFIG" ]]; then
  echo "Error: $_N2O_CONFIG not found. Are you in the project root?" >&2
  return 1 2>/dev/null || exit 1
fi

export N2O_VERSION=$(jq -r '.n2o_version' "$_N2O_CONFIG")
export N2O_PROJECT=$(jq -r '.project_name' "$_N2O_CONFIG")
