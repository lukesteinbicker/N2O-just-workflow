# =============================================================================
# PIN COMMAND
# =============================================================================

cmd_pin() {
  local project_path=""
  local unpin=false
  local pin_version=""

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --unpin) unpin=true; shift ;;
      -*)      log_error "Unknown option: $1"; exit 1 ;;
      *)
        if [[ -z "$project_path" ]]; then
          project_path="$1"
        else
          pin_version="$1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$project_path" ]]; then
    log_error "Usage: n2o pin <project-path> [<version>] [--unpin]"
    exit 1
  fi

  project_path="$(cd "$project_path" && pwd)"

  if [[ ! -f "$project_path/.pm/config.json" ]]; then
    log_error "Not an N2O project (missing .pm/config.json). Run 'n2o init' first."
    exit 1
  fi

  local config="$project_path/.pm/config.json"
  local tmp
  tmp=$(mktemp)

  if $unpin; then
    jq 'del(.n2o_version_pinned)' "$config" > "$tmp"
    mv "$tmp" "$config"
    log_success "Unpinned $(basename "$project_path") — will sync to latest on next 'n2o sync'"
    return
  fi

  # Default to current n2o_version if no version specified
  if [[ -z "$pin_version" ]]; then
    pin_version=$(jq -r '.n2o_version // "unknown"' "$config")
  fi

  jq --arg v "$pin_version" '.n2o_version_pinned = $v' "$config" > "$tmp"
  mv "$tmp" "$config"
  log_success "Pinned $(basename "$project_path") to v$pin_version"
}

# =============================================================================
# SYNC COMMAND
# =============================================================================

cmd_sync() {
  local project_path=""
  local dry_run=false
  local sync_all=false
  local force=false
  local sync_only=""
  local quiet=false
  local pull_tasks=false

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)      dry_run=true; shift ;;
      --all)          sync_all=true; shift ;;
      --force)        force=true; shift ;;
      --quiet)        quiet=true; shift ;;
      --pull-tasks)   pull_tasks=true; shift ;;
      --only=*)       sync_only="${1#--only=}"; shift ;;
      --only)         sync_only="$2"; shift 2 ;;
      -*)             log_error "Unknown option: $1"; exit 1 ;;
      *)              project_path="$1"; shift ;;
    esac
  done

  # Handle --pull-tasks: pull task state from Supabase for all active sprints
  if $pull_tasks; then
    local db="$N2O_DIR/.pm/tasks.db"
    if [[ ! -f "$db" ]]; then
      log_error "Database not found at $db"
      exit 1
    fi

    local supabase_client="$N2O_DIR/scripts/coordination/supabase-client.sh"
    if [[ ! -f "$supabase_client" ]]; then
      log_error "supabase-client.sh not found"
      exit 1
    fi

    source "$supabase_client"
    if [[ "$_SUPABASE_CONFIGURED" != "true" ]]; then
      log_warn "Supabase not configured — cannot pull tasks"
      exit 1
    fi

    local my_id
    my_id=$(git config user.name 2>/dev/null || hostname -s 2>/dev/null || echo "unknown")

    local sprints
    sprints=$(sqlite3 "$db" "SELECT DISTINCT sprint FROM tasks WHERE status IN ('pending','red');" 2>/dev/null)
    if [[ -z "$sprints" ]]; then
      log_info "No active sprints to pull"
      return
    fi

    log_header "Pulling task state from Supabase"
    while IFS= read -r s; do
      [[ -z "$s" ]] && continue
      log_info "Pulling sprint: $s"
      supabase_pull_tasks "$s" "$db" "$my_id" || true
    done <<< "$sprints"
    log_success "Task pull complete"
    return
  fi

  if [[ -n "${sync_only:-}" ]]; then
    validate_sync_categories "$sync_only"
  fi

  if $sync_all; then
    if [[ ! -f "$PROJECTS_FILE" ]]; then
      log_error "No projects registered. Use 'n2o init <path> --register' first."
      exit 1
    fi

    local projects
    projects=$(jq -r '.projects[]' "$PROJECTS_FILE")
    local count
    count=$(echo "$projects" | wc -l)
    if ! $quiet; then
      log_header "Syncing $count registered projects (v$VERSION)"
    fi

    while IFS= read -r p; do
      if ! $quiet; then echo ""; fi
      sync_project "$p" "$dry_run" "$force" "$sync_only" "$quiet"
    done <<< "$projects"
    return
  fi

  if [[ -z "$project_path" ]]; then
    log_error "Usage: n2o sync <project-path> [--dry-run] [--force] [--quiet] or n2o sync --all [--dry-run] [--force]"
    exit 1
  fi

  project_path="$(cd "$project_path" && pwd)"
  sync_project "$project_path" "$dry_run" "$force" "$sync_only" "$quiet"
}

sync_project() {
  local project_path="$1"
  local dry_run="$2"
  local force="${3:-false}"
  local sync_only="${4:-}"
  local quiet="${5:-false}"
  local changes=0
  local skipped=0

  # Global change counter (used by sync_directory and quiet summary)
  SYNC_CHANGE_COUNT=0

  # In quiet mode, shadow log functions to no-ops
  if $quiet; then
    log_info()    { :; }
    log_success() { :; }
    log_header()  { :; }
    # log_warn and log_error still emit in quiet mode
  fi

  if $dry_run; then
    log_header "DRY RUN — Sync: $project_path"
  else
    log_header "Syncing: $project_path"
  fi

  # Verify it's an n2o project
  if [[ ! -f "$project_path/.pm/config.json" ]]; then
    log_error "Not an N2O project (missing .pm/config.json). Run 'n2o init' first."
    return 1
  fi

  local project_version
  project_version=$(jq -r '.n2o_version // "unknown"' "$project_path/.pm/config.json")

  # Check version pin
  local pinned_version
  pinned_version=$(jq -r '.n2o_version_pinned // ""' "$project_path/.pm/config.json")

  if [[ -n "$pinned_version" ]] && ! $force; then
    # Check if framework version is newer than pinned version
    version_compare "$VERSION" "$pinned_version"
    local cmp=$?
    if [[ $cmp -eq 0 ]]; then
      log_warn "Project pinned to v$pinned_version (current framework: v$VERSION)"
      log_info "Use 'n2o sync --force' to upgrade, or 'n2o pin --unpin' to remove the pin."
      return 0
    fi
  fi

  log_info "Current version: $project_version → $VERSION"

  # Show what changed between versions
  show_changelog "$project_version" "$VERSION"

  if [[ -n "$sync_only" ]]; then
    log_info "Selective sync: $sync_only"
  fi

  local backup_dir="$project_path/.n2o-backup/$(date +%Y%m%d-%H%M%S)"
  local schema_changed=false

  # Set up sync context for sync_directory (checksum protection + force flag)
  SYNC_FORCE="$force"
  SYNC_CHECKSUMS_FILE="$project_path/.pm/.skill-checksums.json"

  # ---- Sync agents → .claude/skills/ ----
  log_header "Framework files"

  # Sync agents
  if should_sync_category "agents" "$sync_only"; then
    if [[ -d "$N2O_DIR/02-agents" ]]; then
      sync_directory "$N2O_DIR/02-agents" "$project_path/.claude/skills" "$backup_dir" "$dry_run" "agents"
    fi
  fi

  # Sync patterns
  if should_sync_category "patterns" "$sync_only"; then
    if [[ -d "$N2O_DIR/03-patterns" ]]; then
      sync_directory "$N2O_DIR/03-patterns" "$project_path/.claude/skills" "$backup_dir" "$dry_run" "patterns"
    fi
  fi

  # Sync schema.sql
  if should_sync_category "schema" "$sync_only"; then
    if [[ -f "$N2O_DIR/.pm/schema.sql" ]]; then
      if ! diff -q "$N2O_DIR/.pm/schema.sql" "$project_path/.pm/schema.sql" &>/dev/null; then
        schema_changed=true
        if $dry_run; then
          log_warn "WOULD UPDATE: .pm/schema.sql"
          diff --color=auto "$project_path/.pm/schema.sql" "$N2O_DIR/.pm/schema.sql" 2>/dev/null || true
        else
          backup_file "$project_path/.pm/schema.sql" "$backup_dir"
          cp "$N2O_DIR/.pm/schema.sql" "$project_path/.pm/schema.sql"
          log_success "Updated .pm/schema.sql"
        fi
        ((SYNC_CHANGE_COUNT++)) || true
      else
        log_info "Unchanged: .pm/schema.sql"
      fi
    fi
  fi

  # Sync rates.json (always, no category filter — it's infrastructure)
  if [[ -f "$N2O_DIR/templates/rates.json" ]]; then
    local dest_rates="$project_path/.pm/rates.json"
    if [[ ! -f "$dest_rates" ]] || ! diff -q "$N2O_DIR/templates/rates.json" "$dest_rates" &>/dev/null; then
      if $dry_run; then
        log_warn "WOULD UPDATE: .pm/rates.json"
      else
        cp "$N2O_DIR/templates/rates.json" "$dest_rates"
        log_success "Updated .pm/rates.json"
        ((SYNC_CHANGE_COUNT++)) || true
      fi
    fi
  fi

  # Sync scripts
  if should_sync_category "scripts" "$sync_only"; then
    if [[ -d "$N2O_DIR/scripts" ]]; then
      sync_directory "$N2O_DIR/scripts" "$project_path/scripts" "$backup_dir" "$dry_run" "scripts"
    fi
  fi

  # ---- Skip project files ----
  log_header "Project files (never touched)"
  for pf in ".pm/config.json" ".pm/schema-extensions.sql" "CLAUDE.md" ".mcp.json"; do
    if [[ -f "$project_path/$pf" ]]; then
      log_info "Skipped: $pf"
      ((skipped++)) || true
    fi
  done

  # ---- Apply pending migrations ----
  if ! $dry_run && [[ -f "$project_path/.pm/tasks.db" ]]; then
    log_header "Migrations"
    backup_file "$project_path/.pm/tasks.db" "$backup_dir"
    apply_migrations "$project_path"

    # Re-apply schema-extensions after migrations
    if [[ -f "$project_path/.pm/schema-extensions.sql" ]]; then
      if grep -qE '^\s*(CREATE|ALTER|INSERT|DROP)' "$project_path/.pm/schema-extensions.sql" 2>/dev/null; then
        sqlite3 "$project_path/.pm/tasks.db" < "$project_path/.pm/schema-extensions.sql" 2>/dev/null || true
        log_info "Re-applied schema-extensions.sql"
      fi
    fi
  fi

  # ---- Update version in config ----
  if ! $dry_run; then
    local tmp
    tmp=$(mktemp)
    if $force && [[ -n "$pinned_version" ]]; then
      # Force sync: update both version and pin
      jq --arg ver "$VERSION" '.n2o_version = $ver | .n2o_version_pinned = $ver' "$project_path/.pm/config.json" > "$tmp"
    else
      jq --arg ver "$VERSION" '.n2o_version = $ver' "$project_path/.pm/config.json" > "$tmp"
    fi
    mv "$tmp" "$project_path/.pm/config.json"
  fi

  # ---- Ensure SessionStart hook is registered ----
  if ! $dry_run && should_sync_category "scripts" "$sync_only"; then
    register_session_hook "$project_path"
  fi

  # ---- Supabase task state sync (--force) ----
  if $force && ! $dry_run && [[ -f "$project_path/.pm/tasks.db" ]]; then
    local supabase_client="$project_path/scripts/coordination/supabase-client.sh"
    if [[ -f "$supabase_client" ]]; then
      log_header "Supabase task sync"
      (
        cd "$project_path"
        source "$supabase_client"
        if [[ "$_SUPABASE_CONFIGURED" == "true" ]]; then
          # Sync all active sprints
          local sprints
          sprints=$(sqlite3 "$project_path/.pm/tasks.db" "
            SELECT DISTINCT sprint FROM tasks WHERE status != 'green';
          " 2>/dev/null)
          local sync_ok=true
          while IFS= read -r sprint; do
            [[ -z "$sprint" ]] && continue
            if supabase_sync_all_tasks "$sprint" "$project_path/.pm/tasks.db" >/dev/null 2>&1; then
              log_success "Synced sprint: $sprint"
            else
              log_warn "Failed to sync sprint: $sprint"
              sync_ok=false
            fi
          done <<< "$sprints"
          # Log the manual sync event
          local agent_id
          agent_id="manual-$(hostname -s 2>/dev/null || echo 'local')-$$"
          supabase_log_event "manual_sync" "$agent_id" "" "" \
            '{"trigger":"n2o sync --force"}' >/dev/null 2>&1 || true
          if $sync_ok; then
            log_success "Task state synced to Supabase"
          fi
        else
          log_info "Supabase not configured — skipped task state sync"
        fi
      )
    fi
  fi

  # ---- Summary ----
  if $quiet; then
    # Quiet mode: single summary line if files changed, nothing if up-to-date
    if [[ ${SYNC_CHANGE_COUNT:-0} -gt 0 ]]; then
      echo "N2O auto-synced: v${project_version} → v${VERSION} (${SYNC_CHANGE_COUNT} files updated)"
    fi
  else
    echo ""
    if $dry_run; then
      log_info "Dry run complete. No files were modified."
    else
      log_success "Sync complete. Version: $VERSION"
      if [[ -d "$backup_dir" ]]; then
        log_info "Backups saved to: .n2o-backup/$(basename "$backup_dir")/"
      fi
    fi
  fi
}

# Read a checksum from the skill checksums file
# Usage: get_stored_checksum <checksums_file> <key>
get_stored_checksum() {
  local checksums_file="$1"
  local key="$2"
  if [[ -f "$checksums_file" ]]; then
    jq -r --arg k "$key" '.[$k] // ""' "$checksums_file" 2>/dev/null
  fi
}

# Write/update a checksum in the skill checksums file
# Usage: set_stored_checksum <checksums_file> <key> <checksum>
set_stored_checksum() {
  local checksums_file="$1"
  local key="$2"
  local checksum="$3"
  local tmp
  tmp=$(mktemp)
  if [[ -f "$checksums_file" ]]; then
    jq --arg k "$key" --arg v "$checksum" '.[$k] = $v' "$checksums_file" > "$tmp"
  else
    jq -n --arg k "$key" --arg v "$checksum" '{($k): $v}' > "$tmp"
  fi
  mv "$tmp" "$checksums_file"
}

# Sync a source directory into a destination, with checksum-based skill protection
sync_directory() {
  local src="$1"
  local dest="$2"
  local backup_dir="$3"
  local dry_run="$4"
  local label="$5"
  local force="${SYNC_FORCE:-false}"
  local checksums_file="${SYNC_CHECKSUMS_FILE:-}"
  local protect_skills=false

  # Agents and patterns categories get checksum protection
  if [[ "$label" == "agents" || "$label" == "patterns" ]]; then
    protect_skills=true
  fi

  mkdir -p "$dest"

  # Use rsync-like approach: find all files in source, compare with dest
  while IFS= read -r src_file; do
    local rel="${src_file#$src/}"
    local dest_file="$dest/$rel"

    if [[ -f "$dest_file" ]]; then
      if ! diff -q "$src_file" "$dest_file" &>/dev/null; then
        # Check skill protection for SKILL.md files in agents/patterns
        if $protect_skills && [[ "$rel" == */SKILL.md ]] && ! $force && [[ -n "$checksums_file" ]]; then
          local stored_checksum
          stored_checksum=$(get_stored_checksum "$checksums_file" "$label/$rel")
          local current_checksum
          current_checksum=$(file_checksum "$dest_file")

          if [[ -n "$stored_checksum" && "$current_checksum" != "$stored_checksum" ]]; then
            # Locally modified — skip
            log_warn "Skipping $rel (locally modified)"
            continue
          fi
        fi

        if $dry_run; then
          log_warn "WOULD UPDATE: $label/$rel"
        else
          backup_file "$dest_file" "$backup_dir"
          mkdir -p "$(dirname "$dest_file")"
          cp "$src_file" "$dest_file"
          log_success "Updated: $label/$rel"
          ((SYNC_CHANGE_COUNT++)) || true

          # Update stored checksum after overwrite
          if $protect_skills && [[ "$rel" == */SKILL.md ]] && [[ -n "$checksums_file" ]]; then
            set_stored_checksum "$checksums_file" "$label/$rel" "$(file_checksum "$dest_file")"
          fi
        fi
      fi
    else
      if $dry_run; then
        log_warn "WOULD ADD: $label/$rel"
      else
        mkdir -p "$(dirname "$dest_file")"
        cp "$src_file" "$dest_file"
        log_success "Added: $label/$rel"
        ((SYNC_CHANGE_COUNT++)) || true

        # Record checksum for new skill files
        if $protect_skills && [[ "$rel" == */SKILL.md ]] && [[ -n "$checksums_file" ]]; then
          set_stored_checksum "$checksums_file" "$label/$rel" "$(file_checksum "$dest_file")"
        fi
      fi
    fi
  done < <(find "$src" -type f -not -name '.DS_Store')
}

# Back up a file before overwriting
backup_file() {
  local file="$1"
  local backup_dir="$2"

  if [[ -f "$file" ]]; then
    local rel="${file#$project_path/}"
    local backup_path="$backup_dir/$rel"
    mkdir -p "$(dirname "$backup_path")"
    cp "$file" "$backup_path"
  fi
}

