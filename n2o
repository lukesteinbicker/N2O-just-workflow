# Format a number with commas (e.g., 1234567 -> 1,234,567)
format_number() {
  local n="$1"
  # Handle empty/null
  if [[ -z "$n" || "$n" == "null" ]]; then
    echo "0"
    return
  fi
  # Use printf with locale-aware grouping, fall back to awk
  # LC_NUMERIC=en_US printf is unreliable across platforms, so use awk
  printf "%d" "$n" 2>/dev/null | awk '{
    s = $0
    len = length(s)
    out = ""
    for (i = len; i > 0; i--) {
      out = substr(s, i, 1) out
      if ((len - i + 1) % 3 == 0 && i > 1)
        out = "," out
    }
    print out
  }'
}

cmd_stats_compare() {
  local skill_name="$1"
  local json_output="$2"
  local db
  db="$(resolve_project_db)"

  # ---- JSON output mode ----
  if [[ "$json_output" == "true" ]]; then
    local token_json duration_json precision_json

    token_json=$(sqlite3 -json "$db" "
      SELECT skill_name, skill_version, invocations, total_input_tokens, total_output_tokens, avg_tokens_per_call
      FROM skill_version_token_usage
      WHERE skill_name = '$skill_name'
      ORDER BY skill_version;
    " 2>/dev/null || echo "[]")
    [[ -z "$token_json" ]] && token_json="[]"

    duration_json=$(sqlite3 -json "$db" "
      SELECT skill_name, skill_version, invocations, avg_seconds, min_seconds, max_seconds
      FROM skill_version_duration
      WHERE skill_name = '$skill_name'
      ORDER BY skill_version;
    " 2>/dev/null || echo "[]")
    [[ -z "$duration_json" ]] && duration_json="[]"

    precision_json=$(sqlite3 -json "$db" "
      SELECT skill_name, skill_version, tasks, avg_exploration_ratio
      FROM skill_version_precision
      WHERE skill_name = '$skill_name'
      ORDER BY skill_version;
    " 2>/dev/null || echo "[]")
    [[ -z "$precision_json" ]] && precision_json="[]"

    jq -n \
      --arg skill "$skill_name" \
      --argjson token_usage "$token_json" \
      --argjson duration "$duration_json" \
      --argjson precision "$precision_json" \
      '{
        skill: $skill,
        comparison: {
          token_usage: $token_usage,
          duration: $duration,
          precision: $precision
        }
      }'
    return
  fi

  # ---- Formatted terminal output ----
  log_header "Version Comparison: $skill_name"

  # --- Token Usage ---
  local token_data
  token_data=$(sqlite3 -separator '|' "$db" "
    SELECT skill_version, invocations, total_input_tokens, total_output_tokens, avg_tokens_per_call
    FROM skill_version_token_usage
    WHERE skill_name = '$skill_name'
    ORDER BY skill_version;
  " 2>/dev/null || echo "")

  echo ""
  if [[ -n "$token_data" ]]; then
    printf "  ${BOLD}Token Usage:${NC}\n"
    printf "  ${BOLD}%-12s %8s %12s %12s %10s${NC}\n" "Version" "Calls" "Input" "Output" "Avg/Call"
    printf "  %-12s %8s %12s %12s %10s\n" "----------" "--------" "-----------" "-----------" "--------"
    while IFS='|' read -r version calls inp outp avg; do
      printf "  %-12s %8s %12s %12s %10s\n" "$version" "$calls" "$(format_number "$inp")" "$(format_number "$outp")" "$(format_number "$avg")"
    done <<< "$token_data"
  else
    echo -e "  ${YELLOW}No token data for ${skill_name}.${NC}"
  fi

  echo ""

  # --- Duration ---
  local duration_data
  duration_data=$(sqlite3 -separator '|' "$db" "
    SELECT skill_version, invocations, avg_seconds, min_seconds, max_seconds
    FROM skill_version_duration
    WHERE skill_name = '$skill_name'
    ORDER BY skill_version;
  " 2>/dev/null || echo "")

  if [[ -n "$duration_data" ]]; then
    printf "  ${BOLD}Duration (seconds):${NC}\n"
    printf "  ${BOLD}%-12s %8s %10s %10s %10s${NC}\n" "Version" "Calls" "Avg" "Min" "Max"
    printf "  %-12s %8s %10s %10s %10s\n" "----------" "--------" "--------" "--------" "--------"
    while IFS='|' read -r version calls avg mn mx; do
      printf "  %-12s %8s %10s %10s %10s\n" "$version" "$calls" "$avg" "$mn" "$mx"
    done <<< "$duration_data"
  else
    echo -e "  ${YELLOW}No duration data for ${skill_name}.${NC}"
  fi

  echo ""

  # --- Exploration Ratio ---
  local precision_data
  precision_data=$(sqlite3 -separator '|' "$db" "
    SELECT skill_version, tasks, avg_exploration_ratio
    FROM skill_version_precision
    WHERE skill_name = '$skill_name'
    ORDER BY skill_version;
  " 2>/dev/null || echo "")

  if [[ -n "$precision_data" ]]; then
    printf "  ${BOLD}Exploration Ratio:${NC}\n"
    printf "  ${BOLD}%-12s %8s %10s${NC}\n" "Version" "Tasks" "Avg Ratio"
    printf "  %-12s %8s %10s\n" "----------" "--------" "--------"
    while IFS='|' read -r version tasks ratio; do
      # Color ratio: green if <0.3, yellow if 0.3-0.6, red if >0.6
      local ratio_color="$GREEN"
      if [[ -n "$ratio" ]]; then
        local ratio_int
        ratio_int=$(echo "$ratio" | awk '{printf "%d", $1 * 100}')
        if [[ "$ratio_int" -gt 60 ]]; then
          ratio_color="$RED"
        elif [[ "$ratio_int" -gt 30 ]]; then
          ratio_color="$YELLOW"
        fi
      fi
      printf "  %-12s %8s ${ratio_color}%10s${NC}\n" "$version" "$tasks" "$ratio"
    done <<< "$precision_data"
  else
    echo -e "  ${YELLOW}No precision data for ${skill_name}.${NC}"
  fi

  echo ""
}

cmd_stats() {
  local json_output=false
  local compare_skill=""

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_output=true; shift ;;
      --compare) compare_skill="$2"; shift 2 ;;
      --compare=*) compare_skill="${1#--compare=}"; shift ;;
      -*)     log_error "Unknown option: $1"; exit 1 ;;
      *)      log_error "Unknown argument: $1"; exit 1 ;;
    esac
  done

  local db
  db="$(resolve_project_db)"

  # Check for database
  if [[ ! -f "$db" ]]; then
    log_error "Database not found at $db"
    log_error "Run 'n2o init' first, then populate the database."
    exit 1
  fi

  # Auto-refresh transcript data if the collection script exists
  if [[ -f "$N2O_DIR/scripts/collect-transcripts.sh" ]]; then
    if ! $json_output; then
      log_info "Refreshing transcript data..."
    fi
    (cd "$N2O_DIR" && bash scripts/collect-transcripts.sh) &>/dev/null || true
  fi

  # ---- Compare mode: delegate to cmd_stats_compare ----
  if [[ -n "$compare_skill" ]]; then
    cmd_stats_compare "$compare_skill" "$json_output"
    return
  fi

  # ---- JSON output mode ----
  if $json_output; then
    local sessions_json tool_usage_json sprint_json available_json

    sessions_json=$(sqlite3 -json "$db" "
      SELECT
        COUNT(*) FILTER (WHERE parent_session_id IS NULL) as main_sessions,
        COUNT(*) FILTER (WHERE parent_session_id IS NOT NULL) as subagent_sessions,
        COUNT(*) as total_sessions,
        MAX(started_at) as last_session,
        MAX(session_id) as last_session_id,
        COALESCE(SUM(total_input_tokens), 0) as total_input_tokens,
        COALESCE(SUM(total_output_tokens), 0) as total_output_tokens
      FROM transcripts;
    " 2>/dev/null || echo "[]")
    [[ -z "$sessions_json" ]] && sessions_json="[]"

    tool_usage_json=$(sqlite3 -json "$db" "
      SELECT tool_name, invocations as calls, sessions
      FROM skill_usage
      ORDER BY invocations DESC
      LIMIT 10;
    " 2>/dev/null || echo "[]")
    [[ -z "$tool_usage_json" ]] && tool_usage_json="[]"

    sprint_json=$(sqlite3 -json "$db" "
      SELECT sprint, total_tasks as total, green as done, pending, percent_complete as pct
      FROM sprint_progress
      ORDER BY percent_complete DESC, sprint;
    " 2>/dev/null || echo "[]")
    [[ -z "$sprint_json" ]] && sprint_json="[]"

    available_json=$(sqlite3 -json "$db" "
      SELECT sprint, task_num, title, priority
      FROM available_tasks
      ORDER BY priority ASC NULLS LAST
      LIMIT 15;
    " 2>/dev/null || echo "[]")
    [[ -z "$available_json" ]] && available_json="[]"

    local leadership_json
    leadership_json=$(sqlite3 -json "$db" "
      SELECT
        (SELECT COUNT(*) FROM tasks WHERE status='green' AND completed_at >= datetime('now', '-7 days')) as throughput_7d,
        (SELECT COUNT(*) FROM tasks WHERE status='green' AND completed_at >= datetime('now', '-30 days')) as throughput_30d,
        (SELECT ROUND(AVG((julianday(completed_at) - julianday(started_at)) * 1440), 0) FROM tasks WHERE status='green' AND started_at IS NOT NULL AND completed_at IS NOT NULL AND completed_at >= datetime('now', '-30 days')) as efficiency_30d_min,
        (SELECT ROUND(100.0 * SUM(CASE WHEN testing_posture='A' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 0) FROM tasks WHERE status='green' AND testing_posture IS NOT NULL AND completed_at >= datetime('now', '-30 days')) as quality_30d_pct,
        (SELECT ROUND(AVG((julianday(completed_at) - julianday(started_at)) * 24 / NULLIF(estimated_hours, 0)), 1) FROM tasks WHERE status='green' AND estimated_hours IS NOT NULL AND started_at IS NOT NULL AND completed_at IS NOT NULL AND completed_at >= datetime('now', '-30 days')) as predictability_30d,
        (SELECT ROUND(AVG(estimated_cost_usd), 2) FROM transcripts tr JOIN tasks t ON tr.sprint = t.sprint AND tr.task_num = t.task_num WHERE t.status='green' AND t.completed_at >= datetime('now', '-30 days')) as cost_per_task_30d,
        (SELECT ROUND(AVG(user_message_count), 1) FROM transcripts tr JOIN tasks t ON tr.sprint = t.sprint AND tr.task_num = t.task_num WHERE t.status='green' AND t.completed_at >= datetime('now', '-30 days')) as brain_cycles_30d;
    " 2>/dev/null || echo "[]")
    [[ -z "$leadership_json" ]] && leadership_json="[]"

    local token_quality_json
    token_quality_json=$(sqlite3 -json "$db" "
      SELECT skill_name, sprint, invocations, total_input_tokens, total_output_tokens, avg_tokens_per_call
      FROM skill_token_usage
      ORDER BY total_input_tokens + total_output_tokens DESC
      LIMIT 10;
    " 2>/dev/null || echo "[]")
    [[ -z "$token_quality_json" ]] && token_quality_json="[]"

    local precision_json
    precision_json=$(sqlite3 -json "$db" "
      SELECT sprint, task_num, files_read, files_modified, exploration_ratio
      FROM skill_precision
      WHERE files_read > 0
      ORDER BY exploration_ratio DESC
      LIMIT 10;
    " 2>/dev/null || echo "[]")
    [[ -z "$precision_json" ]] && precision_json="[]"

    local blowup_json
    blowup_json=$(sqlite3 -json "$db" "
      SELECT sprint, task_num, title, type, complexity, estimated_hours, actual_hours, blow_up_ratio
      FROM blow_up_factors
      ORDER BY blow_up_ratio DESC
      LIMIT 5;
    " 2>/dev/null || echo "[]")
    [[ -z "$blowup_json" ]] && blowup_json="[]"

    local skill_versions_json
    skill_versions_json=$(sqlite3 -json "$db" "
      SELECT skill_name, version, framework_version, introduced_at, changelog
      FROM skill_versions
      ORDER BY skill_name, version;
    " 2>/dev/null || echo "[]")
    [[ -z "$skill_versions_json" ]] && skill_versions_json="[]"

    # Sync health: check Supabase config and query transcript sync state
    local sync_health_json
    local supabase_configured=false
    if [[ -n "${SUPABASE_URL:-}" ]]; then
      supabase_configured=true
    elif [[ -f "$N2O_DIR/.pm/config.json" ]]; then
      local sb_url
      sb_url=$(jq -r '.supabase.url // ""' "$N2O_DIR/.pm/config.json" 2>/dev/null)
      [[ -n "$sb_url" ]] && supabase_configured=true
    fi

    sync_health_json=$(sqlite3 "$db" "
      SELECT
        COUNT(*) as total,
        COUNT(*) FILTER (WHERE synced_at IS NOT NULL) as synced,
        COUNT(*) FILTER (WHERE synced_at IS NULL AND sync_attempts < 5) as pending,
        COUNT(*) FILTER (WHERE synced_at IS NULL AND sync_attempts >= 5) as permanently_failed,
        MAX(synced_at) as last_sync_at
      FROM transcripts;
    " -separator '|' 2>/dev/null || echo "0|0|0|0|")

    local sh_total sh_synced sh_pending sh_failed sh_last_sync
    IFS='|' read -r sh_total sh_synced sh_pending sh_failed sh_last_sync <<< "$sync_health_json"
    sh_total="${sh_total:-0}"
    sh_synced="${sh_synced:-0}"
    sh_pending="${sh_pending:-0}"
    sh_failed="${sh_failed:-0}"
    sh_last_sync="${sh_last_sync:-null}"

    local sync_health_obj
    sync_health_obj=$(jq -n \
      --argjson total "$sh_total" \
      --argjson synced "$sh_synced" \
      --argjson pending "$sh_pending" \
      --argjson permanently_failed "$sh_failed" \
      --arg last_sync_at "$sh_last_sync" \
      --argjson supabase_configured "$supabase_configured" \
      '{
        total: $total,
        synced: $synced,
        pending: $pending,
        permanently_failed: $permanently_failed,
        last_sync_at: (if $last_sync_at == "null" or $last_sync_at == "" then null else $last_sync_at end),
        supabase_configured: $supabase_configured
      }')

    # Compose top-level JSON
    jq -n \
      --argjson sessions "$sessions_json" \
      --argjson leadership "$leadership_json" \
      --argjson tools "$tool_usage_json" \
      --argjson sprints "$sprint_json" \
      --argjson available "$available_json" \
      --argjson token_quality "$token_quality_json" \
      --argjson precision "$precision_json" \
      --argjson blowups "$blowup_json" \
      --argjson skill_versions "$skill_versions_json" \
      --argjson sync_health "$sync_health_obj" \
      '{
        sessions: ($sessions[0] // {}),
        leadership_metrics: ($leadership[0] // {}),
        tool_usage: $tools,
        sprint_progress: $sprints,
        available_tasks: $available,
        skill_quality: {
          token_usage: $token_quality,
          precision: $precision,
          blow_up_factors: $blowups
        },
        skill_versions: $skill_versions,
        sync_health: $sync_health
      }'
    return
  fi

  # ---- Formatted terminal output ----

  # === Section 1: Session Summary ===
  log_header "Session Summary"

  local main_sessions subagent_sessions last_session last_session_id total_input total_output
  main_sessions=$(sqlite3 "$db" "SELECT COUNT(*) FROM transcripts WHERE parent_session_id IS NULL;" 2>/dev/null || echo "0")
  subagent_sessions=$(sqlite3 "$db" "SELECT COUNT(*) FROM transcripts WHERE parent_session_id IS NOT NULL;" 2>/dev/null || echo "0")
  last_session=$(sqlite3 "$db" "SELECT COALESCE(MAX(started_at), 'n/a') FROM transcripts;" 2>/dev/null || echo "n/a")
  last_session_id=$(sqlite3 "$db" "SELECT session_id FROM transcripts ORDER BY started_at DESC LIMIT 1;" 2>/dev/null || echo "unknown")
  total_input=$(sqlite3 "$db" "SELECT COALESCE(SUM(total_input_tokens), 0) FROM transcripts;" 2>/dev/null || echo "0")
  total_output=$(sqlite3 "$db" "SELECT COALESCE(SUM(total_output_tokens), 0) FROM transcripts;" 2>/dev/null || echo "0")

  # Truncate session_id display to first 8 chars
  local last_sid_display="${last_session_id:0:8}"
  # Truncate last_session to just the date portion if it has a time
  local last_date="${last_session%T*}"

  echo -e "  Sessions: ${BOLD}${main_sessions}${NC} main + ${BOLD}${subagent_sessions}${NC} subagent transcripts"
  echo -e "  Last session: ${last_date} (${last_sid_display}...)"
  echo -e "  Total tokens: ${BOLD}$(format_number "$total_input")${NC} input / ${BOLD}$(format_number "$total_output")${NC} output"

  # === Section 1b: Leadership Metrics ===
  log_header "Leadership Metrics (last 7d / last 30d)"

  # Helper: query a metric for a time window
  _metric_window() {
    local query="$1"
    local days="$2"
    sqlite3 "$db" "$query" 2>/dev/null || echo "—"
  }

  # 1. Throughput: tasks completed per window
  local tp_7=$(_metric_window "SELECT COUNT(*) FROM tasks WHERE status='green' AND completed_at >= datetime('now', '-7 days');" 7)
  local tp_30=$(_metric_window "SELECT COUNT(*) FROM tasks WHERE status='green' AND completed_at >= datetime('now', '-30 days');" 30)

  # 2. Efficiency: avg minutes per task
  local eff_7=$(_metric_window "SELECT COALESCE(ROUND(AVG((julianday(completed_at) - julianday(started_at)) * 1440), 0), '—') FROM tasks WHERE status='green' AND started_at IS NOT NULL AND completed_at IS NOT NULL AND completed_at >= datetime('now', '-7 days');" 7)
  local eff_30=$(_metric_window "SELECT COALESCE(ROUND(AVG((julianday(completed_at) - julianday(started_at)) * 1440), 0), '—') FROM tasks WHERE status='green' AND started_at IS NOT NULL AND completed_at IS NOT NULL AND completed_at >= datetime('now', '-30 days');" 30)

  # 3. Quality: A-grade rate
  local qual_7=$(_metric_window "SELECT COALESCE(ROUND(100.0 * SUM(CASE WHEN testing_posture='A' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 0), '—') FROM tasks WHERE status='green' AND testing_posture IS NOT NULL AND completed_at >= datetime('now', '-7 days');" 7)
  local qual_30=$(_metric_window "SELECT COALESCE(ROUND(100.0 * SUM(CASE WHEN testing_posture='A' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 0), '—') FROM tasks WHERE status='green' AND testing_posture IS NOT NULL AND completed_at >= datetime('now', '-30 days');" 30)

  # 4. Predictability: blow-up ratio
  local pred_7=$(_metric_window "SELECT COALESCE(ROUND(AVG((julianday(completed_at) - julianday(started_at)) * 24 / NULLIF(estimated_hours, 0)), 1), '—') FROM tasks WHERE status='green' AND estimated_hours IS NOT NULL AND started_at IS NOT NULL AND completed_at IS NOT NULL AND completed_at >= datetime('now', '-7 days');" 7)
  local pred_30=$(_metric_window "SELECT COALESCE(ROUND(AVG((julianday(completed_at) - julianday(started_at)) * 24 / NULLIF(estimated_hours, 0)), 1), '—') FROM tasks WHERE status='green' AND estimated_hours IS NOT NULL AND started_at IS NOT NULL AND completed_at IS NOT NULL AND completed_at >= datetime('now', '-30 days');" 30)

  # 5. Adoption: % tasks using tdd-agent
  local adopt_7=$(_metric_window "SELECT COALESCE(ROUND(100.0 * COUNT(DISTINCT we.sprint || '/' || we.task_num) / NULLIF((SELECT COUNT(*) FROM tasks WHERE status='green' AND completed_at >= datetime('now', '-7 days')), 0), 0), '—') FROM workflow_events we JOIN tasks t ON we.sprint = t.sprint AND we.task_num = t.task_num WHERE we.skill_name = 'tdd-agent' AND t.completed_at >= datetime('now', '-7 days');" 7)
  local adopt_30=$(_metric_window "SELECT COALESCE(ROUND(100.0 * COUNT(DISTINCT we.sprint || '/' || we.task_num) / NULLIF((SELECT COUNT(*) FROM tasks WHERE status='green' AND completed_at >= datetime('now', '-30 days')), 0), 0), '—') FROM workflow_events we JOIN tasks t ON we.sprint = t.sprint AND we.task_num = t.task_num WHERE we.skill_name = 'tdd-agent' AND t.completed_at >= datetime('now', '-30 days');" 30)

  # 6. Dollar cost per task
  local cost_7=$(_metric_window "SELECT COALESCE(ROUND(AVG(tr.estimated_cost_usd), 2), '—') FROM transcripts tr JOIN tasks t ON tr.sprint = t.sprint AND tr.task_num = t.task_num WHERE t.status='green' AND t.completed_at >= datetime('now', '-7 days');" 7)
  local cost_30=$(_metric_window "SELECT COALESCE(ROUND(AVG(tr.estimated_cost_usd), 2), '—') FROM transcripts tr JOIN tasks t ON tr.sprint = t.sprint AND tr.task_num = t.task_num WHERE t.status='green' AND t.completed_at >= datetime('now', '-30 days');" 30)

  # 7. Concurrency: peak overlapping at three tiers via schema views
  local conc_tasks_7=$(_metric_window "SELECT COALESCE(MAX(active), 0) FROM concurrency_tasks WHERE ts >= datetime('now', '-7 days');" 7)
  local conc_tasks_30=$(_metric_window "SELECT COALESCE(MAX(active), 0) FROM concurrency_tasks WHERE ts >= datetime('now', '-30 days');" 30)
  local conc_sess_7=$(_metric_window "SELECT COALESCE(MAX(active), 0) FROM concurrency_sessions WHERE ts >= datetime('now', '-7 days');" 7)
  local conc_sess_30=$(_metric_window "SELECT COALESCE(MAX(active), 0) FROM concurrency_sessions WHERE ts >= datetime('now', '-30 days');" 30)
  local conc_agents_7=$(_metric_window "SELECT COALESCE(MAX(active), 0) FROM concurrency_agents WHERE ts >= datetime('now', '-7 days');" 7)
  local conc_agents_30=$(_metric_window "SELECT COALESCE(MAX(active), 0) FROM concurrency_agents WHERE ts >= datetime('now', '-30 days');" 30)

  # 8. Brain cycles: avg user messages per task
  local brain_7=$(_metric_window "SELECT COALESCE(ROUND(AVG(tr.user_message_count), 1), '—') FROM transcripts tr JOIN tasks t ON tr.sprint = t.sprint AND tr.task_num = t.task_num WHERE t.status='green' AND t.completed_at >= datetime('now', '-7 days');" 7)
  local brain_30=$(_metric_window "SELECT COALESCE(ROUND(AVG(tr.user_message_count), 1), '—') FROM transcripts tr JOIN tasks t ON tr.sprint = t.sprint AND tr.task_num = t.task_num WHERE t.status='green' AND t.completed_at >= datetime('now', '-30 days');" 30)

  printf "  ${BOLD}%-20s %10s %10s${NC}\n" "Metric" "7 days" "30 days"
  printf "  %-20s %10s %10s\n" "--------------------" "----------" "----------"
  printf "  %-20s %10s %10s\n" "Throughput" "${tp_7} tasks" "${tp_30} tasks"
  printf "  %-20s %10s %10s\n" "Efficiency" "${eff_7} min" "${eff_30} min"
  printf "  %-20s %10s %10s\n" "Quality" "${qual_7}%" "${qual_30}%"
  printf "  %-20s %10s %10s\n" "Predictability" "${pred_7}x" "${pred_30}x"
  printf "  %-20s %10s %10s\n" "Adoption" "${adopt_7}%" "${adopt_30}%"
  printf "  %-20s %10s %10s\n" "Cost/Task" "\$${cost_7}" "\$${cost_30}"
  printf "  %-20s %10s %10s\n" "Peak Tasks" "${conc_tasks_7}" "${conc_tasks_30}"
  printf "  %-20s %10s %10s\n" "Peak Sessions" "${conc_sess_7}" "${conc_sess_30}"
  printf "  %-20s %10s %10s\n" "Peak Agents" "${conc_agents_7}" "${conc_agents_30}"
  printf "  %-20s %10s %10s\n" "Brain Cycles" "${brain_7} msgs" "${brain_30} msgs"

  # === Section 1c: Skill Versions ===
  log_header "Skill Versions"

  local skill_versions_data
  skill_versions_data=$(sqlite3 -separator '|' "$db" "
    SELECT skill_name, version, date(introduced_at)
    FROM skill_versions
    ORDER BY skill_name;
  " 2>/dev/null || echo "")

  if [[ -n "$skill_versions_data" ]]; then
    printf "  ${BOLD}%-27s %-10s %12s${NC}\n" "Skill" "Version" "Since"
    printf "  %-27s %-10s %12s\n" "---------------------------" "----------" "------------"
    while IFS='|' read -r sv_name sv_version sv_since; do
      printf "  %-27s %10s %12s\n" "$sv_name" "$sv_version" "$sv_since"
    done <<< "$skill_versions_data"
  else
    echo -e "  ${YELLOW}No skill version data available. Run migration 003-skill-versioning.sql.${NC}"
  fi

  # === Section 2: Tool Usage (top 10) ===
  log_header "Tool Usage (top 10)"

  local tool_data
  tool_data=$(sqlite3 -separator '|' "$db" "
    SELECT tool_name, invocations, sessions
    FROM skill_usage
    ORDER BY invocations DESC
    LIMIT 10;
  " 2>/dev/null || echo "")

  if [[ -n "$tool_data" ]]; then
    printf "  ${BOLD}%-20s %8s %8s${NC}\n" "Tool" "Calls" "Sessions"
    printf "  %-20s %8s %8s\n" "--------------------" "--------" "--------"
    while IFS='|' read -r tool_name calls sessions; do
      printf "  %-20s %8s %8s\n" "$tool_name" "$calls" "$sessions"
    done <<< "$tool_data"
  else
    echo -e "  ${YELLOW}No tool usage data available.${NC}"
  fi

  # === Section 3: Sprint Progress ===
  log_header "Sprint Progress"

  local sprint_data
  sprint_data=$(sqlite3 -separator '|' "$db" "
    SELECT sprint, total_tasks, green, pending, CAST(ROUND(percent_complete) AS INTEGER)
    FROM sprint_progress
    ORDER BY percent_complete DESC, sprint;
  " 2>/dev/null || echo "")

  if [[ -n "$sprint_data" ]]; then
    printf "  ${BOLD}%-22s %6s %6s %8s %5s${NC}\n" "Sprint" "Total" "Done" "Pending" "%"
    printf "  %-22s %6s %6s %8s %5s\n" "----------------------" "------" "------" "--------" "-----"
    while IFS='|' read -r sprint total done pending pct; do
      # Color the percentage: green if 100%, yellow if partial, default if 0%
      local pct_color="$NC"
      if [[ "$pct" == "100" ]]; then
        pct_color="$GREEN"
      elif [[ "$pct" -gt 0 ]] 2>/dev/null; then
        pct_color="$YELLOW"
      fi
      printf "  %-22s %6s %6s %8s ${pct_color}%4s%%${NC}\n" "$sprint" "$total" "$done" "$pending" "$pct"
    done <<< "$sprint_data"
  else
    echo -e "  ${YELLOW}No sprint data available.${NC}"
  fi

  # === Section 3b: Sync Health ===
  log_header "Sync Health"

  local supabase_configured=false
  if [[ -n "${SUPABASE_URL:-}" ]]; then
    supabase_configured=true
  elif [[ -f "$N2O_DIR/.pm/config.json" ]]; then
    local sb_url
    sb_url=$(jq -r '.supabase.url // ""' "$N2O_DIR/.pm/config.json" 2>/dev/null)
    [[ -n "$sb_url" ]] && supabase_configured=true
  fi

  if [[ "$supabase_configured" == "false" ]]; then
    echo -e "  ${YELLOW}Supabase not configured — transcripts are local-only.${NC}"
  else
    local sync_data
    sync_data=$(sqlite3 -separator '|' "$db" "
      SELECT
        COUNT(*),
        COUNT(*) FILTER (WHERE synced_at IS NOT NULL),
        COUNT(*) FILTER (WHERE synced_at IS NULL AND sync_attempts < 5),
        COUNT(*) FILTER (WHERE synced_at IS NULL AND sync_attempts >= 5),
        MAX(synced_at)
      FROM transcripts;
    " 2>/dev/null || echo "0|0|0|0|")

    local sh_total sh_synced sh_pending sh_failed sh_last_sync
    IFS='|' read -r sh_total sh_synced sh_pending sh_failed sh_last_sync <<< "$sync_data"
    sh_total="${sh_total:-0}"
    sh_synced="${sh_synced:-0}"
    sh_pending="${sh_pending:-0}"
    sh_failed="${sh_failed:-0}"

    local sync_pct="0.0"
    if [[ "$sh_total" -gt 0 ]] 2>/dev/null; then
      sync_pct=$(awk "BEGIN { printf \"%.1f\", ($sh_synced / $sh_total) * 100 }")
    fi

    printf "  %-24s %s\n" "Total transcripts:" "$(format_number "$sh_total")"
    printf "  %-24s %s  (%s%%)\n" "Synced to cloud:" "$(format_number "$sh_synced")" "$sync_pct"
    printf "  %-24s %s\n" "Pending sync:" "$(format_number "$sh_pending")"
    if [[ "$sh_failed" -gt 0 ]] 2>/dev/null; then
      printf "  ${YELLOW}%-24s %s${NC}\n" "Permanently failed:" "$(format_number "$sh_failed")"
      echo -e "  ${YELLOW}Run: sqlite3 .pm/tasks.db \"SELECT session_id, sync_error FROM transcripts WHERE sync_attempts >= 5\"${NC}"
    else
      printf "  %-24s %s\n" "Permanently failed:" "0"
    fi

    if [[ -n "$sh_last_sync" ]]; then
      # Calculate time since last sync
      local now_epoch last_epoch diff_seconds
      now_epoch=$(date +%s)
      last_epoch=$(date -j -f "%Y-%m-%d %H:%M:%S" "$sh_last_sync" +%s 2>/dev/null || date -d "$sh_last_sync" +%s 2>/dev/null || echo "0")
      if [[ "$last_epoch" -gt 0 ]]; then
        diff_seconds=$((now_epoch - last_epoch))
        if [[ $diff_seconds -lt 60 ]]; then
          printf "  %-24s %s\n" "Last sync:" "${diff_seconds} seconds ago"
        elif [[ $diff_seconds -lt 3600 ]]; then
          printf "  %-24s %s\n" "Last sync:" "$((diff_seconds / 60)) minutes ago"
        elif [[ $diff_seconds -lt 86400 ]]; then
          printf "  %-24s %s\n" "Last sync:" "$((diff_seconds / 3600)) hours ago"
        else
          printf "  %-24s %s\n" "Last sync:" "$((diff_seconds / 86400)) days ago"
        fi
      else
        printf "  %-24s %s\n" "Last sync:" "$sh_last_sync"
      fi
    else
      printf "  %-24s %s\n" "Last sync:" "never"
    fi
  fi

  # === Section 4: Available Tasks ===
  log_header "Available Tasks (next up)"

  local available_data
  available_data=$(sqlite3 -separator '|' "$db" "
    SELECT sprint, task_num, title, COALESCE(priority, 'n/a')
    FROM available_tasks
    ORDER BY priority ASC NULLS LAST
    LIMIT 15;
  " 2>/dev/null || echo "")

  if [[ -n "$available_data" ]]; then
    printf "  ${BOLD}%-16s %-50s %8s${NC}\n" "Sprint/#" "Title" "Priority"
    printf "  %-16s %-50s %8s\n" "----------------" "--------------------------------------------------" "--------"
    while IFS='|' read -r sprint task_num title priority; do
      local sprint_task="${sprint}/${task_num}"
      # Truncate title if too long
      if [[ ${#title} -gt 50 ]]; then
        title="${title:0:47}..."
      fi
      printf "  %-16s %-50s %8s\n" "$sprint_task" "$title" "$priority"
    done <<< "$available_data"
  else
    echo -e "  ${GREEN}No pending tasks — all caught up!${NC}"
  fi

  # === Section 5: Skill Quality ===
  log_header "Skill Quality"

  # Token usage by tool
  local token_data
  token_data=$(sqlite3 -separator '|' "$db" "
    SELECT skill_name, sprint, invocations, total_input_tokens, total_output_tokens, avg_tokens_per_call
    FROM skill_token_usage
    ORDER BY total_input_tokens + total_output_tokens DESC
    LIMIT 10;
  " 2>/dev/null || echo "")

  if [[ -n "$token_data" ]]; then
    printf "  ${BOLD}Token Usage by Tool:${NC}\n"
    printf "  ${BOLD}%-15s %-18s %8s %12s %12s %10s${NC}\n" "Tool" "Sprint" "Calls" "Input" "Output" "Avg/Call"
    printf "  %-15s %-18s %8s %12s %12s %10s\n" "---------------" "------------------" "--------" "------------" "------------" "----------"
    while IFS='|' read -r skill sprint calls inp outp avg; do
      printf "  %-15s %-18s %8s %12s %12s %10s\n" "${skill:-all}" "$sprint" "$calls" "$(format_number "$inp")" "$(format_number "$outp")" "$(format_number "$avg")"
    done <<< "$token_data"
  else
    echo -e "  ${YELLOW}No token usage data available. Run collect-transcripts.sh --reparse to populate.${NC}"
  fi

  echo ""

  # Exploration ratio
  local precision_data
  precision_data=$(sqlite3 -separator '|' "$db" "
    SELECT sprint, task_num, files_read, files_modified, exploration_ratio
    FROM skill_precision
    WHERE files_read > 0
    ORDER BY exploration_ratio DESC
    LIMIT 10;
  " 2>/dev/null || echo "")

  if [[ -n "$precision_data" ]]; then
    printf "  ${BOLD}Exploration Ratio (files read vs modified):${NC}\n"
    printf "  ${BOLD}%-16s %8s %10s %8s${NC}\n" "Sprint/#" "Read" "Modified" "Ratio"
    printf "  %-16s %8s %10s %8s\n" "----------------" "--------" "----------" "--------"
    while IFS='|' read -r sprint task_num fread fmod ratio; do
      local sprint_task="${sprint}/${task_num}"
      # Color ratio: green if <0.3, yellow if 0.3-0.6, red if >0.6
      local ratio_color="$GREEN"
      if [[ -n "$ratio" ]]; then
        local ratio_int
        ratio_int=$(echo "$ratio" | awk '{printf "%d", $1 * 100}')
        if [[ "$ratio_int" -gt 60 ]]; then
          ratio_color="$RED"
        elif [[ "$ratio_int" -gt 30 ]]; then
          ratio_color="$YELLOW"
        fi
      fi
      printf "  %-16s %8s %10s ${ratio_color}%8s${NC}\n" "$sprint_task" "$fread" "$fmod" "$ratio"
    done <<< "$precision_data"
  else
    echo -e "  ${YELLOW}No precision data available. Run collect-transcripts.sh --reparse to populate.${NC}"
  fi

  echo ""

  # Blow-up factors
  local blowup_data
  blowup_data=$(sqlite3 -separator '|' "$db" "
    SELECT sprint, task_num, title, type, complexity, estimated_hours, actual_hours, blow_up_ratio
    FROM blow_up_factors
    ORDER BY blow_up_ratio DESC
    LIMIT 5;
  " 2>/dev/null || echo "")

  if [[ -n "$blowup_data" ]]; then
    printf "  ${BOLD}Blow-Up Factors (actual > 2x estimate):${NC}\n"
    printf "  ${BOLD}%-16s %-35s %8s %8s %6s${NC}\n" "Sprint/#" "Title" "Est(h)" "Act(h)" "Ratio"
    printf "  %-16s %-35s %8s %8s %6s\n" "----------------" "-----------------------------------" "--------" "--------" "------"
    while IFS='|' read -r sprint task_num title type complexity est act ratio; do
      local sprint_task="${sprint}/${task_num}"
      if [[ ${#title} -gt 35 ]]; then
        title="${title:0:32}..."
      fi
      printf "  %-16s %-35s %8s %8s ${RED}%5sx${NC}\n" "$sprint_task" "$title" "$est" "$act" "$ratio"
    done <<< "$blowup_data"
  else
    echo -e "  ${YELLOW}No blow-up data available (no tasks exceeded 2x estimate).${NC}"
  fi

  echo ""
}

# =============================================================================
# MIGRATE COMMAND
# =============================================================================

cmd_migrate() {
  local project_path=""
  local action=""
  local old_schema=""
  local new_schema=""

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --apply)    action="apply"; shift ;;
      --status)   action="status"; shift ;;
      --generate) action="generate"; shift ;;
      --old)      old_schema="$2"; shift 2 ;;
      --new)      new_schema="$2"; shift 2 ;;
      -*)         log_error "Unknown option: $1"; exit 1 ;;
      *)          project_path="$1"; shift ;;
    esac
  done

  if [[ -z "$action" ]]; then
    log_error "Usage: n2o migrate --apply|--status|--generate <project-path>"
    exit 1
  fi

  if [[ -z "$project_path" ]]; then
    log_error "Usage: n2o migrate --$action <project-path>"
    exit 1
  fi

  project_path="$(cd "$project_path" && pwd)"

  if [[ ! -f "$project_path/.pm/config.json" ]]; then
    log_error "Not an N2O project (missing .pm/config.json). Run 'n2o init' first."
    exit 1
  fi

  case "$action" in
    apply)
      log_header "Applying migrations: $project_path"
      apply_migrations "$project_path"
      ;;
    status)
      migrate_status "$project_path"
      ;;
    generate)
      generate_migration "$project_path" "$old_schema" "$new_schema"
      ;;
  esac
}

migrate_status() {
  local project_path="$1"
  local db="$project_path/.pm/tasks.db"
  local migrations_dir="$project_path/.pm/migrations"

  if [[ ! -f "$db" ]]; then
    log_error "Database not found: $db"
    exit 1
  fi

  # Ensure _migrations table exists
  sqlite3 "$db" "CREATE TABLE IF NOT EXISTS _migrations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,
    applied_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    framework_version TEXT,
    checksum TEXT
  );" 2>/dev/null

  local applied_count
  applied_count=$(sqlite3 "$db" "SELECT COUNT(*) FROM _migrations;" 2>/dev/null || echo "0")

  # Count pending (migration files not in _migrations)
  local pending_count=0
  if [[ -d "$migrations_dir" ]]; then
    local migration_files
    migration_files=$(find "$migrations_dir" -maxdepth 1 -name '*.sql' -type f 2>/dev/null | sort)
    if [[ -n "$migration_files" ]]; then
      while IFS= read -r f; do
        local name
        name=$(basename "$f" .sql)
        local is_applied
        is_applied=$(sqlite3 "$db" "SELECT COUNT(*) FROM _migrations WHERE name='$name';" 2>/dev/null)
        if [[ "$is_applied" == "0" ]]; then
          ((pending_count++)) || true
        fi
      done <<< "$migration_files"
    fi
  fi

  log_header "Migration Status: $(basename "$project_path")"
  echo -e "  ${BOLD}$applied_count${NC} applied, ${BOLD}$pending_count${NC} pending"

  if [[ "$applied_count" -gt 0 ]]; then
    echo ""
    echo -e "  ${BOLD}Applied:${NC}"
    sqlite3 "$db" "SELECT '    ' || name || ' (' || framework_version || ', ' || applied_at || ')' FROM _migrations ORDER BY id;" 2>/dev/null
  fi

  if [[ "$pending_count" -gt 0 ]]; then
    echo ""
    echo -e "  ${BOLD}Pending:${NC}"
    if [[ -d "$migrations_dir" ]]; then
      local migration_files
      migration_files=$(find "$migrations_dir" -maxdepth 1 -name '*.sql' -type f 2>/dev/null | sort)
      while IFS= read -r f; do
        local name
        name=$(basename "$f" .sql)
        local is_applied
        is_applied=$(sqlite3 "$db" "SELECT COUNT(*) FROM _migrations WHERE name='$name';" 2>/dev/null)
        if [[ "$is_applied" == "0" ]]; then
          echo "    $name"
        fi
      done <<< "$migration_files"
    fi
  fi

  echo ""
}

# Parse columns from a CREATE TABLE block (one column per line)
# Outputs: column_name<TAB>full_definition (one per line)
# Skips PRIMARY KEY lines, UNIQUE lines, CHECK lines, FOREIGN KEY lines
parse_table_columns() {
  local table_body="$1"
  echo "$table_body" | while IFS= read -r line; do
    # Trim whitespace
    local trimmed
    trimmed=$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
    # Skip empty, PRIMARY KEY, UNIQUE, CHECK, FOREIGN KEY, closing paren
    case "$trimmed" in
      "") continue ;;
      PRIMARY*) continue ;;
      UNIQUE*) continue ;;
      CHECK*) continue ;;
      FOREIGN*) continue ;;
      ");"*) continue ;;
      ")"*) continue ;;
    esac
    # Remove trailing comma
    trimmed="${trimmed%,}"
    # Extract column name (first word)
    local col_name
    col_name=$(echo "$trimmed" | awk '{print $1}')
    # Output: name<TAB>full_definition
    printf '%s\t%s\n' "$col_name" "$trimmed"
  done
}

# Extract table names and their bodies from a schema file
# Outputs blocks: TABLE_NAME<newline>body_lines<newline>END_TABLE
extract_tables() {
  local schema_file="$1"
  local in_table=false
  local table_name=""
  local body=""

  while IFS= read -r line; do
    if [[ "$line" =~ ^CREATE[[:space:]]+TABLE[[:space:]]+(IF[[:space:]]+NOT[[:space:]]+EXISTS[[:space:]]+)?([a-zA-Z_][a-zA-Z0-9_]*) ]]; then
      in_table=true
      table_name="${BASH_REMATCH[2]}"
      body=""
      continue
    fi
    if $in_table; then
      if [[ "$line" =~ ^\)\; ]]; then
        echo "TABLE:$table_name"
        echo "$body"
        echo "END_TABLE"
        in_table=false
      else
        if [[ -n "$body" ]]; then
          body="$body"$'\n'"$line"
        else
          body="$line"
        fi
      fi
    fi
  done < "$schema_file"
}

# Extract new CREATE VIEW, CREATE INDEX, CREATE TABLE statements from new schema
# that don't exist in old schema
extract_new_statements() {
  local old_file="$1"
  local new_file="$2"
  local stmt_type="$3"  # TABLE, VIEW, INDEX

  local new_stmts old_stmts
  case "$stmt_type" in
    TABLE)
      new_stmts=$(grep -oE 'CREATE TABLE (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$new_file" 2>/dev/null | awk '{print $NF}' || true)
      old_stmts=$(grep -oE 'CREATE TABLE (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$old_file" 2>/dev/null | awk '{print $NF}' || true)
      ;;
    VIEW)
      new_stmts=$(grep -oE 'CREATE VIEW (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$new_file" 2>/dev/null | awk '{print $NF}' || true)
      old_stmts=$(grep -oE 'CREATE VIEW (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$old_file" 2>/dev/null | awk '{print $NF}' || true)
      ;;
    INDEX)
      new_stmts=$(grep -oE 'CREATE INDEX (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$new_file" 2>/dev/null | awk '{print $NF}' || true)
      old_stmts=$(grep -oE 'CREATE INDEX (IF NOT EXISTS )?[a-zA-Z_][a-zA-Z0-9_]*' "$old_file" 2>/dev/null | awk '{print $NF}' || true)
      ;;
  esac

  # Find names in new but not in old
  local name
  for name in $new_stmts; do
    if ! echo "$old_stmts" | grep -qx "$name" 2>/dev/null; then
      echo "$name"
    fi
  done
}

# Get next migration number (zero-padded to 3 digits)
next_migration_number() {
  local migrations_dir="$1"
  local max_num=0

  if [[ -d "$migrations_dir" ]]; then
    local f
    for f in "$migrations_dir"/*.sql; do
      [[ -e "$f" ]] || continue
      local basename_f
      basename_f=$(basename "$f")
      local num
      num=$(echo "$basename_f" | grep -oE '^[0-9]+' || true)
      if [[ -n "$num" ]] && [[ "$((10#$num))" -gt "$max_num" ]]; then
        max_num=$((10#$num))
      fi
    done
  fi

  printf '%03d' $((max_num + 1))
}

# Extract a full statement block (CREATE TABLE/VIEW/INDEX) from a schema file by name
extract_statement_block() {
  local schema_file="$1"
  local stmt_type="$2"   # TABLE, VIEW, INDEX
  local name="$3"

  case "$stmt_type" in
    TABLE)
      # Extract from CREATE TABLE to );
      awk "/CREATE TABLE.*${name}/,/^\\);/" "$schema_file"
      ;;
    VIEW)
      # Views may have DROP VIEW before CREATE VIEW — grab both
      awk "/DROP VIEW.*${name}/,/;/" "$schema_file"
      echo ""
      awk "/CREATE VIEW.*${name}/,/;/" "$schema_file"
      ;;
    INDEX)
      grep "CREATE INDEX.*${name}" "$schema_file"
      ;;
  esac
}

generate_migration() {
  local project_path="$1"
  local old_schema="$2"
  local new_schema="$3"
  local migrations_dir="$project_path/.pm/migrations"

  if [[ -z "$old_schema" ]] || [[ -z "$new_schema" ]]; then
    log_error "Usage: n2o migrate --generate <project-path> --old <old.sql> --new <new.sql>"
    exit 1
  fi

  if [[ ! -f "$old_schema" ]]; then
    log_error "Old schema file not found: $old_schema"
    exit 1
  fi

  if [[ ! -f "$new_schema" ]]; then
    log_error "New schema file not found: $new_schema"
    exit 1
  fi

  mkdir -p "$migrations_dir"

  local migration_sql=""

  # 1. Diff columns in existing tables (ADD/DROP COLUMN)
  local old_tables new_tables
  old_tables=$(extract_tables "$old_schema")
  new_tables=$(extract_tables "$new_schema")

  # Build list of table names from old schema
  local old_table_names
  old_table_names=$(echo "$old_tables" | grep '^TABLE:' | sed 's/^TABLE://')

  # For each table that exists in both old and new, diff columns
  local tname
  for tname in $old_table_names; do
    # Check if table also exists in new
    if ! echo "$new_tables" | grep -q "^TABLE:$tname$"; then
      continue
    fi

    # Get old columns
    local old_body new_body
    old_body=$(echo "$old_tables" | awk "/^TABLE:${tname}$/,/^END_TABLE$/" | grep -v "^TABLE:" | grep -v "^END_TABLE$")
    new_body=$(echo "$new_tables" | awk "/^TABLE:${tname}$/,/^END_TABLE$/" | grep -v "^TABLE:" | grep -v "^END_TABLE$")

    local old_cols new_cols
    old_cols=$(parse_table_columns "$old_body")
    new_cols=$(parse_table_columns "$new_body")

    local old_col_names new_col_names
    old_col_names=$(echo "$old_cols" | awk -F'\t' '{print $1}' | grep -v '^$' || true)
    new_col_names=$(echo "$new_cols" | awk -F'\t' '{print $1}' | grep -v '^$' || true)

    # Added columns (in new but not in old)
    local col
    for col in $new_col_names; do
      if ! echo "$old_col_names" | grep -qx "$col" 2>/dev/null; then
        # Get full definition
        local col_def
        col_def=$(echo "$new_cols" | awk -F'\t' -v c="$col" '$1 == c {print $2}')
        migration_sql="${migration_sql}ALTER TABLE $tname ADD COLUMN $col_def;"$'\n'
      fi
    done

    # Dropped columns (in old but not in new)
    for col in $old_col_names; do
      if ! echo "$new_col_names" | grep -qx "$col" 2>/dev/null; then
        migration_sql="${migration_sql}ALTER TABLE $tname DROP COLUMN $col;"$'\n'
      fi
    done
  done

  # 2. New tables (in new but not in old)
  local new_table_names
  new_table_names=$(extract_new_statements "$old_schema" "$new_schema" "TABLE")
  for tname in $new_table_names; do
    local block
    block=$(extract_statement_block "$new_schema" "TABLE" "$tname")
    migration_sql="${migration_sql}${block}"$'\n'
  done

  # 3. New views (in new but not in old)
  local new_view_names
  new_view_names=$(extract_new_statements "$old_schema" "$new_schema" "VIEW")
  for tname in $new_view_names; do
    local block
    block=$(extract_statement_block "$new_schema" "VIEW" "$tname")
    migration_sql="${migration_sql}${block}"$'\n'
  done

  # 4. New indexes (in new but not in old)
  local new_index_names
  new_index_names=$(extract_new_statements "$old_schema" "$new_schema" "INDEX")
  for tname in $new_index_names; do
    local block
    block=$(extract_statement_block "$new_schema" "INDEX" "$tname")
    migration_sql="${migration_sql}${block}"$'\n'
  done

  # Check if there are any changes
  local trimmed_sql
  trimmed_sql=$(echo "$migration_sql" | sed '/^$/d' | sed 's/^[[:space:]]*//')
  if [[ -z "$trimmed_sql" ]]; then
    log_info "No schema changes detected."
    return 0
  fi

  # Write migration file
  local num
  num=$(next_migration_number "$migrations_dir")
  local migration_file="$migrations_dir/${num}-auto-generated.sql"
  echo "-- Auto-generated migration" > "$migration_file"
  echo "-- Generated at: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$migration_file"
  echo "" >> "$migration_file"
  echo "$migration_sql" >> "$migration_file"

  log_success "Generated migration: $(basename "$migration_file")"
  log_info "Review the migration before applying:"
  log_info "  cat $migration_file"
}

# =============================================================================
# MAIN
# =============================================================================

main() {
  check_deps

  local command="${1:-}"
  shift 2>/dev/null || true

  case "$command" in
    setup)
      cmd_setup "$@"
      ;;
    init)
      cmd_init "$@"
      ;;
    pin)
      cmd_pin "$@"
      ;;
    sync)
      cmd_sync "$@"
      ;;
    migrate)
      cmd_migrate "$@"
      ;;
    check)
      cmd_check "$@"
      ;;
    stats)
      cmd_stats "$@"
      ;;
    version|--version|-v)
      if [[ "${1:-}" == "bump" ]]; then
        shift
        cmd_version_bump "$@"
      else
        echo "n2o v$VERSION"
      fi
      ;;
    help|--help|-h|"")
      echo "n2o — N2O Workflow Framework CLI (v$VERSION)"
      echo ""
      echo "Usage:"
      echo "  n2o setup [--framework-path <path>] [--no-auto-sync] [--auto-pull] [--name <name>]"
      echo "      First-time developer setup. Writes ~/.n2o/config.json."
      echo ""
      echo "  n2o init <project-path> [--interactive] [--register]"
      echo "      Bootstrap a new project with N2O workflow files."
      echo ""
      echo "  n2o sync <project-path> [--dry-run] [--force] [--quiet] [--only=agents,patterns,schema,scripts]"
      echo "      Push framework updates to a project. --quiet emits single summary line."
      echo ""
      echo "  n2o sync --all [--dry-run] [--force]"
      echo "      Push framework updates to all registered projects."
      echo ""
      echo "  n2o pin <project-path> [<version>]"
      echo "      Pin a project to a framework version. Sync will skip pinned projects."
      echo ""
      echo "  n2o pin <project-path> --unpin"
      echo "      Remove version pin, allowing sync to update to latest."
      echo ""
      echo "  n2o migrate --apply <project-path>"
      echo "      Apply pending schema migrations to a project's tasks.db."
      echo ""
      echo "  n2o migrate --status <project-path>"
      echo "      Show applied and pending migrations for a project."
      echo ""
      echo "  n2o migrate --generate <project-path>"
      echo "      Auto-generate a migration by diffing schema.sql changes."
      echo ""
      echo "  n2o check <project-path>"
      echo "      Run health check on an initialized project."
      echo ""
      echo "  n2o stats [--json] [--compare <skill-name>]"
      echo "      Show project statistics: sessions, tool usage, sprint progress."
      echo "      --compare: compare metrics across versions of the specified skill."
      echo ""
      echo "  n2o version"
      echo "      Print the current framework version."
      echo ""
      echo "  n2o version bump [patch|minor|major]"
      echo "      Bump framework version, generate changelog from git log, create git tag."
      echo ""
      echo "  n2o help"
      echo "      Show this help message."
      ;;
    *)
      log_error "Unknown command: $command"
      echo "Run 'n2o help' for usage."
      exit 1
      ;;
  esac
}

main "$@"
