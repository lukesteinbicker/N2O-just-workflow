# Supabase Management API (required)
SUPABASE_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-access-token

# Supabase Auth (for JWT verification — optional until RBAC is enabled)
SUPABASE_JWT_SECRET=your-jwt-secret

# Toggl time tracking (required for time tracking features)
TOGGL_API_TOKEN=your-toggl-token
TOGGL_WORKSPACE_ID=your-workspace-id

# SMS Companion (required for SMS features)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
ANTHROPIC_API_KEY=your-anthropic-key

# Dev mode (set to "true" for local development without auth)
NOS_DEV_MODE=true

# Server port (default: 4000)
PORT=4000
